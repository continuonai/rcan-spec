{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://rcan.dev/schemas/rcan-config.schema.json",
  "title": "RCAN Configuration",
  "description": "Robot Configuration and Autonomy Notation — the config format for OpenCastor robots.",
  "type": "object",
  "required": ["rcan_version", "metadata", "agent", "physics", "drivers", "network", "rcan_protocol"],
  "additionalProperties": false,
  "properties": {
    "rcan_version": {
      "type": "string",
      "description": "Semantic version of the RCAN spec this config targets.",
      "pattern": "^\\d+\\.\\d+(\\.\\d+(-[a-zA-Z0-9.]+)?)?$"
    },
    "metadata": {
      "type": "object",
      "description": "Descriptive information about the robot.",
      "required": ["robot_name", "robot_uuid", "author", "license"],
      "additionalProperties": true,
      "properties": {
        "robot_name": { "type": "string", "minLength": 1 },
        "robot_uuid": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        },
        "author": { "type": "string", "minLength": 1 },
        "license": { "type": "string" },
        "ruri": {
          "type": "string",
          "description": "Explicit RCAN URI for this robot. Auto-generated if omitted.",
          "pattern": "^rcan://[a-zA-Z0-9_*-]+\\.[a-zA-Z0-9_*-]+\\.[a-zA-Z0-9_*-]+(/[a-zA-Z0-9_/-]*)?$"
        },
        "manufacturer": { "type": "string" },
        "model": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "description": "ISO 8601 timestamp of config creation" },
        "description": { "type": "string", "description": "Human-readable description of this robot configuration." },
        "version": { "type": "string" },
        "device_id": { "type": "string" }
      }
    },
    "agent": {
      "type": "object",
      "description": "AI provider and model configuration.",
      "required": ["provider", "model"],
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["google", "openai", "anthropic", "ollama", "openrouter", "huggingface", "llamacpp", "llama.cpp", "llama-cpp", "mlx", "mlx-lm", "vllm-mlx", "apple", "claude_oauth", "groq"]
        },
        "model": { "type": "string", "minLength": 1 },
        "vision_enabled": { "type": "boolean", "default": true },
        "latency_budget_ms": { "type": "integer", "minimum": 0 },
        "safety_stop": { "type": "boolean", "default": true },
        "api_key": { "type": "string", "description": "Fallback API key. Prefer env vars instead." },
        "base_url": { "type": "string", "description": "Custom API base URL for providers that support it." },
        "agentic_vision": { "type": "boolean" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "secondary_models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "provider": { "type": "string" },
              "model": { "type": "string" },
              "role": { "type": "string" }
            }
          }
        },
        "prompt_caching": { "type": "boolean", "default": true },
        "cache_alert_threshold": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.5 }
      }
    },
    "tiered_brain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "planner_interval": { "type": "integer", "minimum": 1 },
        "uncertainty_threshold": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "reactive": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hailo_vision": { "type": "boolean", "default": false },
        "hailo_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "hailo_model_path": { "type": "string" },
        "hailo_stop_distance_m": { "type": "number", "minimum": 0 },
        "hailo_warn_distance_m": { "type": "number", "minimum": 0 },
        "hailo_calibration": { "type": "number", "minimum": 0 },
        "min_obstacle_m": { "type": "number", "minimum": 0 },
        "fallback_provider": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider": { "type": "string" },
            "model": { "type": "string" }
          }
        }
      }
    },
    "learner": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "cadence": { "type": "string" },
        "cadence_n": { "type": "integer", "minimum": 1 },
        "max_retries": { "type": "integer", "minimum": 0 },
        "auto_apply_config": { "type": "boolean", "default": true },
        "auto_apply_behavior": { "type": "boolean", "default": false },
        "auto_apply_code": { "type": "boolean", "default": false }
      }
    },
    "physics": {
      "type": "object",
      "required": ["type", "dof"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["differential_drive", "ackermann", "serial_manipulator", "parallel_manipulator", "holonomic", "custom", "mecanum", "four_wheel_drive", "self_balancing", "omni"]
        },
        "dof": { "type": "integer", "minimum": 1 },
        "chassis": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "wheel_base_mm": { "type": "number", "minimum": 0 },
            "wheelbase_mm": { "type": "number", "minimum": 0 },
            "track_width_mm": { "type": "number", "minimum": 0 },
            "wheel_radius_mm": { "type": "number", "minimum": 0 }
          }
        },
        "kinematics": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "length_mm", "axis"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "length_mm": { "type": "number", "minimum": 0 },
              "mass_g": { "type": "number", "minimum": 0 },
              "axis": { "type": "string", "enum": ["x", "y", "z"] },
              "limits_deg": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 2 }
            }
          }
        }
      }
    },
    "drivers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["protocol"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "link_id": { "type": "string" },
          "protocol": { "type": "string", "minLength": 1 },
          "port": { "oneOf": [{ "type": "string" }, { "type": "integer", "minimum": 0 }] },
          "address": { "type": "string" },
          "frequency": { "type": "integer", "minimum": 0 },
          "baud_rate": { "type": "integer", "minimum": 0 },
          "hardware_id": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string" },
        "resolution": { "type": "array", "items": { "type": "integer", "minimum": 1 }, "minItems": 2, "maxItems": 2 },
        "framerate": { "type": "integer", "minimum": 1 },
        "depth_enabled": { "type": "boolean", "default": false },
        "fps": { "type": "integer", "minimum": 1 },
        "imu_enabled": { "type": "boolean", "default": false }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tts_enabled": { "type": "boolean" },
        "engine": { "type": "string" },
        "language": { "type": "string" },
        "output_device": { "type": "string" }
      }
    },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "whatsapp": { "type": "object", "additionalProperties": true, "properties": { "enabled": { "type": "boolean" } } },
        "telegram": { "type": "object", "additionalProperties": true, "properties": { "enabled": { "type": "boolean" } } },
        "discord": { "type": "object", "additionalProperties": true, "properties": { "enabled": { "type": "boolean" } } },
        "slack": { "type": "object", "additionalProperties": true, "properties": { "enabled": { "type": "boolean" } } }
      }
    },
    "network": {
      "type": "object",
      "required": ["telemetry_stream"],
      "additionalProperties": false,
      "properties": {
        "telemetry_stream": { "type": "boolean" },
        "sim_to_real_sync": { "type": "boolean" },
        "allow_remote_override": { "type": "boolean" }
      }
    },
    "rcan_protocol": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8000 },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "enable_mdns": { "type": "boolean", "default": false },
        "enable_jwt": { "type": "boolean", "default": false },
        "registry": { "type": "string" }
      }
    },
    "agent_roster": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "enabled"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "enabled": { "type": "boolean" },
          "config": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "swarm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "sync_interval_s": { "type": "number", "minimum": 1 },
        "patch_sync": { "type": "boolean", "default": false },
        "shared_memory_path": { "type": "string" }
      }
    },
    "connection": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" }
      }
    },
    "notes": {
      "oneOf": [
        { "type": "string" },
        { "type": "object", "additionalProperties": true }
      ]
    },
    "safety": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "obstacle_stop_cm": { "type": "number", "default": 30 },
        "estop_on_startup": { "type": "boolean", "default": false }
      }
    },
    "ros2": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "namespace": { "type": "string" },
        "domain_id": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
