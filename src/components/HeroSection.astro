---
import InteractiveNetwork from './InteractiveNetwork.astro';
---
<section class="relative py-20 lg:py-32 overflow-hidden min-h-[90vh] flex items-center justify-center">
  <!-- Dynamic Background -->
  <InteractiveNetwork />
  
  <div class="absolute inset-0 pointer-events-none bg-gradient-to-b from-transparent via-bg/50 to-bg z-10"></div>

  <div class="relative z-20 text-center max-w-5xl mx-auto px-6">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-text-muted mb-8 animate-fade-in opacity-0 backdrop-blur-md" style="animation-delay: 0.1s">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
      v1.3 — Whole Solution Release
    </div>

    <h1 class="text-6xl lg:text-8xl font-bold tracking-tight mb-8 animate-fade-in opacity-0" style="animation-delay: 0.2s">
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-white via-text to-text-muted">The Open Standard for</span>
      <br />
      <span class="bg-clip-text text-transparent bg-gradient-to-r from-accent via-cyan-400 to-purple-500 drop-shadow-[0_0_15px_rgba(34,211,238,0.5)]">Robot Safety</span>
    </h1>

    <p class="text-xl lg:text-2xl text-text-muted max-w-2xl mx-auto mb-8 animate-fade-in opacity-0 leading-relaxed" style="animation-delay: 0.3s">
      An open standard any robot can implement. Identity, accountability, and safety — built in.
    </p>

    <!-- Three-step flow -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12 animate-fade-in opacity-0 text-sm" style="animation-delay: 0.35s">
      <div class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full backdrop-blur-sm">
        <span>🔖</span>
        <span><strong class="text-white">Identify</strong> <span class="text-text-muted">— Every robot gets a globally unique RRN</span></span>
      </div>
      <span class="text-text-muted hidden sm:block">→</span>
      <div class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full backdrop-blur-sm">
        <span>🔐</span>
        <span><strong class="text-white">Sign</strong> <span class="text-text-muted">— Every action carries model identity + confidence</span></span>
      </div>
      <span class="text-text-muted hidden sm:block">→</span>
      <div class="flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full backdrop-blur-sm">
        <span>✅</span>
        <span><strong class="text-white">Prove</strong> <span class="text-text-muted">— Tamper-evident audit trail, any runtime</span></span>
      </div>
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in opacity-0" style="animation-delay: 0.4s">
      <a href="/quickstart" class="px-8 py-4 bg-accent text-bg font-bold text-lg rounded-full hover:bg-accent-hover transform hover:scale-105 transition-all duration-200 shadow-[0_0_30px_-5px_var(--color-accent)] ring-2 ring-accent/50 ring-offset-2 ring-offset-bg">
        Get Started →
      </a>
      <a href="/registry/" class="px-8 py-4 bg-white/5 border border-white/10 text-text font-semibold text-lg rounded-full hover:bg-white/10 hover:border-white/20 transition-all duration-200 backdrop-blur-md flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
        View Registry →
      </a>
    </div>
  </div>
</section>
