<BaseLayout title="Registry Federation Protocol" description="RCAN §18 — cross-registry JWT trust chains, federated consent record portability, FEDERATION_SYNC payload, and trust anchor discovery.">
  <nav class="doc-nav">
    <a href="/docs/">← Documentation</a>
