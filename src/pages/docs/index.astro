---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Documentation" description="RCAN Protocol documentation - guides, references, and specifications for robot communication.">
  <div class="docs-header">
    <h1>Documentation</h1>
    <p class="lead">Everything you need to know about the RCAN Protocol.</p>
  </div>

  <div class="docs-grid">
    <section class="doc-section">
      <h2>Getting Started</h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/introduction/" class="doc-link">
            <span class="doc-title">Introduction to RCAN</span>
            <span class="doc-desc">What is RCAN and why it matters for robotics</span>
          </a>
        </li>
        <li>
          <a href="/docs/quick-start/" class="doc-link">
            <span class="doc-title">Quick Start Guide</span>
            <span class="doc-desc">Get up and running in 5 minutes</span>
          </a>
        </li>
        <li>
          <a href="/docs/concepts/" class="doc-link">
            <span class="doc-title">Core Concepts</span>
            <span class="doc-desc">RRN, RURI, registries, and roles explained</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="doc-section">
      <h2>Protocol Details</h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/ruri/" class="doc-link">
            <span class="doc-title">RURI Format</span>
            <span class="doc-desc">Robot URI structure and parsing</span>
          </a>
        </li>
        <li>
          <a href="/docs/discovery/" class="doc-link">
            <span class="doc-title">Discovery Protocol</span>
            <span class="doc-desc">mDNS and network discovery</span>
          </a>
        </li>
        <li>
          <a href="/docs/auth/" class="doc-link">
            <span class="doc-title">Authentication</span>
            <span class="doc-desc">Role-based access control system</span>
          </a>
        </li>
        <li>
          <a href="/docs/messages/" class="doc-link">
            <span class="doc-title">Message Types <span class="badge-v15">v1.5</span></span>
            <span class="doc-desc">All 31 RCAN v1.5 message types — canonical integer table, version compat, CONFIG_UPDATE, fleet ops</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="doc-section">
      <h2>Registry</h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/registration/" class="doc-link">
            <span class="doc-title">Registering a Robot</span>
            <span class="doc-desc">Three ways to add your robot</span>
          </a>
        </li>
        <li>
          <a href="/docs/schema/" class="doc-link">
            <span class="doc-title">YAML Schema</span>
            <span class="doc-desc">Robot definition format reference</span>
          </a>
        </li>
        <li>
          <a href="/docs/ownership/" class="doc-link">
            <span class="doc-title">Ownership History</span>
            <span class="doc-desc">Transfer and tracking features</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="doc-section">
      <h2>Safety &amp; Compliance</h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/safety/" class="doc-link">
            <span class="doc-title">Safety &amp; P66 Conformance</span>
            <span class="doc-desc">ESTOP, hardware safety, clock sync, and audit export</span>
          </a>
        </li>
        <li>
          <a href="/docs/replay-prevention/" class="doc-link">
            <span class="doc-title">Replay Attack Prevention <span class="badge-v15">v1.5</span></span>
            <span class="doc-desc">§8.3 — msg_id seen-set and timestamp freshness window</span>
          </a>
        </li>
        <li>
          <a href="/docs/qos/" class="doc-link">
            <span class="doc-title">QoS &amp; Delivery Guarantees <span class="badge-v15">v1.5</span></span>
            <span class="doc-desc">§5.3 — fire-and-forget, at-least-once, ESTOP exactly-once</span>
          </a>
        </li>
        <li>
          <a href="/docs/training-consent/" class="doc-link">
            <span class="doc-title">Training Data Consent <span class="badge-v15">v1.5</span></span>
            <span class="doc-desc">§17 — EU AI Act Article 10, biometric data, right-to-erasure</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="doc-section">
      <h2>Security <span class="badge-v15-section">v1.5</span></h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/revocation/" class="doc-link">
            <span class="doc-title">Robot Identity Revocation</span>
            <span class="doc-desc">§13 — ROBOT_REVOCATION, TTL cache, offline quarantine</span>
          </a>
        </li>
        <li>
          <a href="/docs/key-rotation/" class="doc-link">
            <span class="doc-title">Key Rotation</span>
            <span class="doc-desc">§8.6 — JWKS, key_id, grace period, KEY_ROTATION message</span>
          </a>
        </li>
        <li>
          <a href="/docs/cloud-relay/" class="doc-link">
            <span class="doc-title">Cloud Relay Identity</span>
            <span class="doc-desc">§8.5 — sender_type, cloud_function identity, audit trail</span>
          </a>
        </li>
        <li>
          <a href="/docs/delegation/" class="doc-link">
            <span class="doc-title">Command Delegation Chain</span>
            <span class="doc-desc">§12 — R2R delegation, max 4 hops, physical presence</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="doc-section">
      <h2>Consent &amp; Access <span class="badge-v15-section">v1.5</span></h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/consent/" class="doc-link">
            <span class="doc-title">Consent Wire Protocol</span>
            <span class="doc-desc">§11.2 — CONSENT_REQUEST/GRANT/DENY, third-party control flow</span>
          </a>
        </li>
        <li>
          <a href="/docs/offline/" class="doc-link">
            <span class="doc-title">Offline Operation</span>
            <span class="doc-desc">§14 — cached key auth, restricted mode, reconnection</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="doc-section">
      <h2>v1.6 Features <span class="badge-v16-section">v1.6</span></h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/federation/" class="doc-link">
            <span class="doc-title">Registry Federation Protocol <span class="badge-v16">v1.6</span></span>
            <span class="doc-desc">§18 — cross-registry JWT trust chains, federated consent, ESTOP propagation</span>
          </a>
        </li>
        <li>
          <a href="/docs/constrained-transport/" class="doc-link">
            <span class="doc-title">Constrained Transport Encoding <span class="badge-v16">v1.6</span></span>
            <span class="doc-desc">§19 — RCAN-Compact (CBOR), RCAN-Minimal (32-byte LoRa), BLE L2CAP framing</span>
          </a>
        </li>
        <li>
          <a href="/docs/multimodal/" class="doc-link">
            <span class="doc-title">Multi-Modal Payloads <span class="badge-v16">v1.6</span></span>
            <span class="doc-desc">§5.4 — media_chunks[], inline/reference mode, streaming video, TRAINING_DATA migration</span>
          </a>
        </li>
        <li>
          <a href="/docs/identity/" class="doc-link">
            <span class="doc-title">Identity Verification &amp; LoA <span class="badge-v16">v1.6</span></span>
            <span class="doc-desc">§8.7 — Level of Assurance 1/2/3, registry tiers, FIDO2/WebAuthn, P66 min_loa_for_control</span>
          </a>
        </li>
      </ul>
    </section>

    <section class="doc-section">
      <h2>Integration</h2>
      <ul class="doc-list">
        <li>
          <a href="/docs/badges/" class="doc-link">
            <span class="doc-title">Badges and Embeds</span>
            <span class="doc-desc">Add RCAN badges to your projects</span>
          </a>
        </li>
        <li>
          <a href="/docs/qr-codes/" class="doc-link">
            <span class="doc-title">QR Codes</span>
            <span class="doc-desc">Generate and use robot QR codes</span>
          </a>
        </li>
        <li>
          <a href="/api/" class="doc-link">
            <span class="doc-title">API Reference</span>
            <span class="doc-desc">REST API documentation</span>
          </a>
        </li>
        <li>
          <a href="/docs/error-codes/" class="doc-link">
            <span class="doc-title">Error Codes</span>
            <span class="doc-desc">API, federation, and SDK error reference</span>
          </a>
        </li>
      </ul>
    </section>
  </div>
</BaseLayout>

<style>
  .docs-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .lead {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-top: 0.5rem;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .doc-section {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
  }

  .doc-section h2 {
    font-size: 1.1rem;
    margin: 0 0 1rem;
    color: var(--color-accent);
  }

  .doc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .doc-list li {
    margin-bottom: 0.75rem;
  }

  .doc-list li:last-child {
    margin-bottom: 0;
  }

  .doc-link {
    display: block;
    padding: 0.75rem;
    border-radius: 8px;
    transition: all 0.2s;
  }

  .doc-link:hover {
    background: rgba(34, 211, 238, 0.1);
    text-decoration: none;
  }

  .doc-title {
    display: block;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
  }

  .doc-desc {
    display: block;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .badge-v15 {
    display: inline-block;
    background: rgba(34, 211, 238, 0.12);
    color: var(--color-accent);
    border: 1px solid rgba(34, 211, 238, 0.35);
    border-radius: 3px;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.05rem 0.3rem;
    vertical-align: middle;
  }

  .badge-v15-section {
    display: inline-block;
    background: rgba(34, 211, 238, 0.12);
    color: var(--color-accent);
    border: 1px solid rgba(34, 211, 238, 0.35);
    border-radius: 3px;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.05rem 0.3rem;
    vertical-align: middle;
  }

  .badge-v16 {
    display: inline-block;
    background: rgba(168, 85, 247, 0.12);
    color: #a855f7;
    border: 1px solid rgba(168, 85, 247, 0.35);
    border-radius: 3px;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.05rem 0.3rem;
    vertical-align: middle;
  }

  .badge-v16-section {
    display: inline-block;
    background: rgba(168, 85, 247, 0.12);
    color: #a855f7;
    border: 1px solid rgba(168, 85, 247, 0.35);
    border-radius: 3px;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.05rem 0.3rem;
    vertical-align: middle;
  }

  @media (max-width: 768px) {
    .docs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
