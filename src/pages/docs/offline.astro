  .badge-new {
    display: inline-block;
    background: rgba(34, 211, 238, 0.15);
    color: var(--color-accent);
    border: 1px solid rgba(34, 211, 238, 0.4);
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.1rem 0.4rem;
    vertical-align: middle;
    letter-spacing: 0.05em;
  }

