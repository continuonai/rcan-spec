---
import BaseLayout from '../../layouts/BaseLayout.astro';

const implementations = [
  {
    name: "OpenCastor",
    lang: "Python",
    description: "Reference RCAN runtime (v2026.3.13.10). Confidence gates, HiTL gates, thought logging, commitment chain audit, multi-provider AI brain, hardware auto-detection, and fleet telemetry. One implementation of RCAN — not required to use the protocol.",
    tier: "verified",
    github: "https://github.com/craigm26/OpenCastor",
    tags: ["Python", "Raspberry Pi", "Safety Gates", "Commitment Chain", "Reference Implementation", "v2026.3.13.10"],
  },
  {
    name: "rcan-py",
    lang: "Python",
    description: "Official Python SDK (v0.3.0). RURI parsing, message construction, Ed25519 signing, schema validation, RegistryClient for rcan.dev API, TypedDicts, exception hierarchy.",
    tier: "verified",
    github: "https://github.com/continuonai/rcan-py",
    tags: ["Python", "SDK", "Registry", "TypedDicts", "v0.3.0"],
  },
  {
    name: "rcan-ts",
    lang: "TypeScript",
    description: "Official TypeScript / Node.js SDK (v0.3.0). RURI parsing, message construction, audit chain, Ed25519 signing. Works in Node, browser (ESM), and CDN (IIFE bundle via unpkg/jsDelivr).",
    tier: "verified",
    github: "https://github.com/continuonai/rcan-ts",
    tags: ["TypeScript", "Node.js", "SDK", "ESM", "CDN bundle", "v0.3.0"],
  },
  {
    name: "Bob",
    lang: "Python",
    description: "Raspberry Pi 5 robot running OpenCastor. Community reference deployment demonstrating the full RCAN stack on consumer hardware.",
    tier: "community",
    github: "https://github.com/craigm26/OpenCastor",
    tags: ["Pi5", "Robot", "OpenCastor"],
  },
  {
    name: "ContinuonOS",
    lang: "Python",
    description: "Cognitive operating layer for RCAN robots. Integrates specialist providers, memory, episode replay, and multi-modal perception.",
    tier: "community",
    github: "https://github.com/continuonai",
    tags: ["Cognitive OS", "Memory", "Perception"],
  },
];

const tierMeta: Record<string, { label: string; color: string; icon: string }> = {
  verified: { label: "Verified ✅", color: "text-green-400 bg-green-400/10 border-green-400/20", icon: "✅" },
  community: { label: "Community ⬜", color: "text-text-muted bg-white/5 border-white/10", icon: "⬜" },
};
---

<BaseLayout
  title="Implementations — RCAN Protocol"
  description="Known implementations of the RCAN protocol: SDKs, robot frameworks, and community projects. Python, TypeScript, and more."
>
  <div class="max-w-5xl mx-auto">

    <!-- Header -->
    <div class="py-16 border-b border-white/5 mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-text-muted mb-6">
        <span class="w-2 h-2 rounded-full bg-accent"></span>
        Protocol v1.3
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-text mb-4 leading-tight">
        Implementations
      </h1>
      <p class="text-xl text-text-muted leading-relaxed max-w-2xl">
        Known implementations of the RCAN protocol — SDKs, robot frameworks, and
        community deployments. Want to add yours?{" "}
        <a href="https://github.com/continuonai/rcan-spec" class="text-accent hover:underline" target="_blank" rel="noopener">
          Open a PR →
        </a>
      </p>
    </div>

    <!-- Tier legend -->
    <div class="flex flex-wrap gap-3 mb-10">
      <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-400/10 border border-green-400/20 text-green-400 text-xs font-medium">
        ✅ Verified — tested against official conformance suite
      </div>
      <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/5 border border-white/10 text-text-muted text-xs font-medium">
        ⬜ Community — self-reported, not independently tested
      </div>
    </div>

    <!-- Card grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {implementations.map(impl => {
        const tier = tierMeta[impl.tier] ?? tierMeta.community;
        return (
          <div class="bg-bg-alt border border-white/5 rounded-2xl p-6 flex flex-col gap-4 hover:border-white/10 transition-colors">
            <!-- Top row -->
            <div class="flex items-start justify-between gap-2">
              <div>
                <h2 class="text-lg font-bold text-text">{impl.name}</h2>
                <span class="text-xs text-text-muted">{impl.lang}</span>
              </div>
              <span class={`flex-shrink-0 text-xs font-medium px-2.5 py-1 rounded-full border ${tier.color}`}>
                {tier.label}
              </span>
            </div>

            <!-- Description -->
            <p class="text-sm text-text-muted leading-relaxed flex-1">{impl.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5">
              {impl.tags.map(tag => (
                <span class="text-xs px-2 py-0.5 rounded bg-white/5 text-text-muted border border-white/5">
                  {tag}
                </span>
              ))}
            </div>

            <!-- GitHub link -->
            <a
              href={impl.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm text-accent hover:underline mt-auto"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              View on GitHub
            </a>
          </div>
        );
      })}
    </div>

    <!-- Add your own -->
    <div class="border border-white/5 rounded-2xl p-8 bg-bg-alt text-center mb-16">
      <h3 class="text-xl font-bold text-text mb-2">Built something with RCAN?</h3>
      <p class="text-text-muted mb-6">
        Add your implementation to this page by opening a pull request on the rcan-spec repo.
        Community implementations welcome — verified status requires conformance suite results.
      </p>
      <a
        href="https://github.com/continuonai/rcan-spec/issues/new?template=implementation.md"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white rounded-lg text-sm font-medium hover:bg-accent/90 transition-colors"
      >
        Submit your implementation →
      </a>
    </div>

  </div>
</BaseLayout>
