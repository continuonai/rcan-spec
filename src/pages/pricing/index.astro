---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Free',
    subtitle: 'Community',
    price: '$0',
    period: 'forever',
    highlight: false,
    badge: '⬜',
    features: [
      'Up to 3 RRNs',
      'Community verification badge (🟡)',
      'Public registry listing',
      'API access — read-only, 100 req/day',
    ],
    cta: 'Register for Free',
    ctaHref: '/registry/submit/',
    ctaStyle: 'outline',
  },
  {
    name: 'Maker',
    subtitle: '',
    price: '$9',
    period: '/year',
    highlight: false,
    badge: '🟡',
    features: [
      'Up to 25 RRNs',
      'Community verification',
      'QR code generation',
      'API access — 1,000 req/day',
      'Email support',
    ],
    cta: 'Get Started',
    ctaHref: '/registry/submit/',
    ctaStyle: 'outline',
  },
  {
    name: 'Manufacturer',
    subtitle: '',
    price: '$299',
    period: '/year',
    highlight: true,
    badge: '🔵',
    features: [
      'Unlimited RRNs',
      'Manufacturer-claimed verification (🔵)',
      'DNS TXT verification tool',
      'API access — 10,000 req/day',
      'Dedicated onboarding',
      'Priority support',
    ],
    cta: 'Contact Us',
    ctaHref: 'mailto:hello@continuon.ai?subject=RCAN+Manufacturer+Plan',
    ctaStyle: 'outline',
  },
  {
    name: 'Enterprise',
    subtitle: '',
    price: '$999',
    period: '/year',
    highlight: false,
    badge: '✅',
    features: [
      'Unlimited RRNs',
      'Manufacturer-verified tier (✅)',
      'Signed attestation review',
      'Live RURI endpoint monitoring',
      'EU AI Act Art. 49 registration support',
      'SLA — 99.9% uptime',
      'Custom API rate limits',
    ],
    cta: 'Contact Us',
    ctaHref: 'mailto:hello@continuon.ai?subject=RCAN+Enterprise+Plan',
    ctaStyle: 'outline',
  },
];

const faqs = [
  {
    q: 'Why charge for robot registration?',
    a: 'Maintaining a globally distributed, always-on registry with verification tooling, API infrastructure, and legal entity support has real costs. Fees keep the registry independent, sustainable, and free from ad-based or data-sale business models. The Free tier ensures the registry is always accessible to the community.'
  },
  {
    q: 'What is an RRN?',
    a: 'An RRN (Robot Registration Number) is a globally unique identifier assigned to a specific robot or robot model. Like a VIN for cars or an ISBN for books, an RRN provides a canonical, machine-readable reference that links to the robot\'s provenance, manufacturer, specifications, and ownership history.'
  },
  {
    q: 'Can I transfer an RRN?',
    a: 'Yes. RRNs can be transferred between owners via a signed transfer request. The registry maintains a full chain-of-custody log so provenance is always auditable. Transfers are free for all paid tiers and available at a small fee on the Free tier.'
  },
  {
    q: 'What is manufacturer verification?',
    a: 'Verification tiers (⬜ unverified → 🟡 community → 🔵 manufacturer-claimed → ✅ manufacturer-verified) indicate how strongly a robot\'s origin has been validated. Manufacturer-claimed (🔵) uses DNS TXT records to prove domain ownership. Manufacturer-verified (✅) involves a signed attestation review by the Registry Foundation — the gold standard for commercial and regulated deployments.'
  },
];
---

<BaseLayout title="Pricing — RCAN Robot Registry" description="Simple, transparent pricing for robot registration. Like domain registration for robots. Free community tier, Maker, Manufacturer, and Enterprise plans.">
  
  <!-- Hero -->
  <div class="text-center py-20 border-b border-white/5">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs font-medium text-text-muted mb-6 backdrop-blur-md">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
      Robot Registration
    </div>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tight mb-6">
      Register Your Robot
    </h1>
    <p class="text-xl text-text-muted max-w-2xl mx-auto leading-relaxed">
      Simple, transparent pricing — like domain registration for robots.
      Choose the tier that fits your scale.
    </p>
  </div>

  <!-- Pricing Cards -->
  <div class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {tiers.map(tier => (
          <div class={`relative flex flex-col rounded-2xl border p-8 transition-all duration-300 hover:-translate-y-1 ${tier.highlight ? 'border-accent/50 bg-accent/5 shadow-[0_0_40px_-10px_rgba(34,211,238,0.3)]' : 'border-white/10 bg-bg-alt/30 hover:border-white/20'}`}>
            {tier.highlight && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 bg-accent text-bg text-xs font-bold rounded-full shadow-lg whitespace-nowrap">
                Most Popular
              </div>
            )}
            
            <!-- Header -->
            <div class="mb-6">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-2xl">{tier.badge}</span>
                <h3 class="text-xl font-bold text-text">{tier.name}</h3>
                {tier.subtitle && <span class="text-xs text-text-muted bg-white/5 px-2 py-0.5 rounded-full">{tier.subtitle}</span>}
              </div>
              <div class="flex items-baseline gap-1">
                <span class={`text-4xl font-bold ${tier.highlight ? 'text-accent' : 'text-text'}`}>{tier.price}</span>
                <span class="text-text-muted text-sm">{tier.period}</span>
              </div>
            </div>

            <!-- Features -->
            <ul class="space-y-3 flex-grow mb-8">
              {tier.features.map(feat => (
                <li class="flex items-start gap-2.5 text-sm text-text-muted">
                  <svg xmlns="http://www.w3.org/2000/svg" class={`w-4 h-4 mt-0.5 flex-shrink-0 ${tier.highlight ? 'text-accent' : 'text-green-400'}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {feat}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <a
              href={tier.ctaHref}
              class={`block text-center py-3 px-6 rounded-xl font-semibold text-sm transition-all duration-200 ${tier.highlight ? 'bg-accent text-bg hover:bg-accent-hover shadow-[0_0_20px_-5px_var(--color-accent)]' : 'bg-white/5 text-text border border-white/10 hover:bg-white/10 hover:border-white/20'}`}
            >
              {tier.cta}
            </a>
          </div>
        ))}
      </div>

      <!-- Provisional pricing note -->
      <p class="mt-10 text-center text-sm text-text-muted/60 max-w-2xl mx-auto">
        The Robot Registry Foundation (proposed governance body) will set final pricing when formally established. Current pricing is provisional.
      </p>
    </div>
  </div>

  <!-- Comparison table summary -->
  <div class="py-10 border-t border-white/5">
    <div class="max-w-4xl mx-auto px-6">
      <h2 class="text-2xl font-bold text-center mb-8">Verification Tiers Explained</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { badge: '⬜', label: 'Unverified', desc: 'No verification — RRN assigned but origin unconfirmed.' },
          { badge: '🟡', label: 'Community', desc: 'Self-reported via public registry form. Free tier and above.' },
          { badge: '🔵', label: 'Mfr-Claimed', desc: 'DNS TXT record proves domain ownership. Manufacturer plan.' },
          { badge: '✅', label: 'Mfr-Verified', desc: 'Signed attestation review by Registry Foundation. Enterprise.' },
        ].map(t => (
          <div class="bg-bg-alt/30 border border-white/5 rounded-xl p-4 text-center">
            <div class="text-3xl mb-2">{t.badge}</div>
            <div class="font-semibold text-sm mb-1">{t.label}</div>
            <div class="text-xs text-text-muted leading-relaxed">{t.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div class="py-20 border-t border-white/5">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions</h2>
      <div class="space-y-6">
        {faqs.map(faq => (
          <div class="bg-bg-alt/30 border border-white/5 rounded-xl p-6 hover:border-white/10 transition-colors">
            <h3 class="font-bold text-text mb-3">{faq.q}</h3>
            <p class="text-text-muted text-sm leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="py-20 text-center border-t border-white/5">
    <h2 class="text-2xl font-bold mb-4">Ready to register your robot?</h2>
    <p class="text-text-muted mb-8 max-w-xl mx-auto">Start with the Free tier — no credit card required. Upgrade when you need manufacturer verification or higher API limits.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="/registry/submit/" class="px-8 py-4 bg-accent text-bg font-bold text-lg rounded-full hover:bg-accent-hover transform hover:scale-105 transition-all duration-200 shadow-[0_0_30px_-5px_var(--color-accent)]">
        Register for Free
      </a>
      <a href="/registry/" class="px-8 py-4 bg-white/5 border border-white/10 text-text font-semibold text-lg rounded-full hover:bg-white/10 hover:border-white/20 transition-all duration-200">
        Browse the Registry
      </a>
    </div>
  </div>

</BaseLayout>
