---
import DocsLayout from '../layouts/DocsLayout.astro';
import CodeWindow from '../components/CodeWindow.astro';

const title = "Quickstart — RCAN Protocol";
const description = "From zero to your first RCAN message in 5 minutes.";
---

<DocsLayout title={title} description={description}>

  <h1>Quickstart</h1>
  <p class="lead text-xl text-text-muted mb-10">From zero to your first RCAN message in 5 minutes.</p>

  <!-- Step 1 -->
  <h2 id="install">
    <span class="text-accent font-mono text-lg mr-2">01</span>Install the SDK
  </h2>

  <!-- SDK Tabs -->
  <div class="not-prose my-6">
    <div class="flex gap-2 mb-0 border-b border-white/10" id="sdk-tabs">
      <button class="sdk-tab px-4 py-2 text-sm font-medium rounded-t-lg border border-b-0 border-white/10 bg-accent/10 text-accent transition-all" data-tab="python">Python</button>
      <button class="sdk-tab px-4 py-2 text-sm font-medium rounded-t-lg border border-b-0 border-white/10 bg-bg-alt/30 text-text-muted hover:text-white transition-all" data-tab="typescript">TypeScript</button>
      <button class="sdk-tab px-4 py-2 text-sm font-medium rounded-t-lg border border-b-0 border-white/10 bg-bg-alt/30 text-text-muted hover:text-white transition-all" data-tab="curl">curl / CDN</button>
    </div>

    <div id="tab-python" class="sdk-panel rounded-b-lg rounded-tr-lg border border-white/10 bg-bg-alt/30 p-4 font-mono text-sm overflow-x-auto">
      <pre class="text-green-400"># Install</pre>
      <pre class="text-white">pip install rcan</pre>
      <pre class="text-text-muted mt-2"># Optional extras</pre>
      <pre class="text-white">pip install rcan[http]    <span class="text-text-muted"># registry client (httpx)</span></pre>
      <pre class="text-white">pip install rcan[crypto]  <span class="text-text-muted"># Ed25519 message signing</span></pre>
      <pre class="text-white">pip install rcan[all]     <span class="text-text-muted"># everything</span></pre>
    </div>

    <div id="tab-typescript" class="sdk-panel hidden rounded-b-lg rounded-tr-lg border border-white/10 bg-bg-alt/30 p-4 font-mono text-sm overflow-x-auto">
      <pre class="text-green-400"># Install</pre>
      <pre class="text-white">npm install @continuonai/rcan-ts</pre>
      <pre class="text-text-muted mt-2"># or yarn</pre>
      <pre class="text-white">yarn add @continuonai/rcan-ts</pre>
      <pre class="text-text-muted mt-2"># Import</pre>
      <pre class="text-white">import &#123; RobotURI, RCANMessage, ConfidenceGate &#125; from '@continuonai/rcan-ts';</pre>
    </div>

    <div id="tab-curl" class="sdk-panel hidden rounded-b-lg rounded-tr-lg border border-white/10 bg-bg-alt/30 p-4 font-mono text-sm overflow-x-auto">
      <pre class="text-green-400"># CDN (no build step)</pre>
      <pre class="text-white">&lt;script src="https://unpkg.com/@continuonai/rcan-ts/dist/rcan.iife.js"&gt;&lt;/script&gt;</pre>
      <pre class="text-white">&lt;script&gt;const uri = RCAN.RobotURI.parse('rcan://registry.rcan.dev/acme/arm/v1/unit-001');&lt;/script&gt;</pre>
      <pre class="text-text-muted mt-2"># Registry API (curl)</pre>
      <pre class="text-white">curl https://rcan.dev/api/v1/robots \</pre>
      <pre class="text-white">  -H 'Content-Type: application/json' \</pre>
      <pre class="text-white">  -d '&#123;"manufacturer":"acme","model":"arm","version":"v1","device_id":"unit-001"&#125;'</pre>
    </div>
  </div>

  <script>
    const tabs = document.querySelectorAll<HTMLButtonElement>('.sdk-tab');
    const panels = document.querySelectorAll<HTMLElement>('.sdk-panel');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.tab;
        tabs.forEach(t => {
          t.classList.toggle('bg-accent/10', t.dataset.tab === target);
          t.classList.toggle('text-accent', t.dataset.tab === target);
          t.classList.toggle('bg-bg-alt/30', t.dataset.tab !== target);
          t.classList.toggle('text-text-muted', t.dataset.tab !== target);
        });
        panels.forEach(p => {
          p.classList.toggle('hidden', p.id !== `tab-${target}`);
        });
      });
    });
  </script>

  <!-- Step 2 -->
  <h2 id="robot-uri">
    <span class="text-accent font-mono text-lg mr-2">02</span>Build a Robot URI
  </h2>
  <p>Every robot has a globally unique, resolvable address. No more "which unit was it?"</p>

  <CodeWindow language="python" title="address.py" code={`from rcan import RobotURI

uri = RobotURI.build(
    manufacturer="acme",
    model="robotarm",
    version="v2",
    device_id="unit-001",
)
print(uri)
# rcan://registry.rcan.dev/acme/robotarm/v2/unit-001

# Parse from a string
uri = RobotURI.parse("rcan://registry.rcan.dev/acme/robotarm/v2/unit-001")
print(uri.namespace)      # acme/robotarm
print(uri.registry_url)   # https://registry.rcan.dev/registry/...`} />

  <!-- Step 3 -->
  <h2 id="confidence-gate">
    <span class="text-accent font-mono text-lg mr-2">03</span>Gate on AI Confidence
  </h2>
  <p>The gate doesn't trust the model — that's the point. The model is right 99.99% of the time. The gate catches the 0.01%.</p>

  <CodeWindow language="python" title="gate.py" code={`from rcan import RCANMessage, ConfidenceGate

gate = ConfidenceGate(threshold=0.8)
confidence = 0.91  # from your AI model

if gate.allows(confidence):
    msg = RCANMessage(
        cmd="move_forward",
        target=uri,
        params={"distance_m": 1.0},
        confidence=confidence,
        model_identity="Qwen2.5-7B-Q4",
    )
    print(msg.to_json(indent=2))
else:
    print(f"Blocked: confidence {confidence} < threshold {gate.threshold}")`} />

  <p>For high-stakes actions, add a <code>HiTLGate</code> to require explicit human approval. See <a href="/spec/#section-16">§16 AI Accountability</a>.</p>

  <!-- Step 4 -->
  <h2 id="audit-chain">
    <span class="text-accent font-mono text-lg mr-2">04</span>Create a Tamper-Evident Audit Record
  </h2>
  <p>Every safety-critical action can be sealed into an HMAC-chained record — forensic-grade proof of what the system did, when, at what confidence.</p>

  <CodeWindow language="python" title="audit.py" code={`from rcan import CommitmentRecord
from rcan.audit import AuditChain

chain = AuditChain(secret="your-hmac-secret")

record = chain.append(CommitmentRecord(
    action="move_forward",
    robot_uri=str(uri),
    confidence=0.91,
    model_identity="Qwen2.5-7B-Q4",
    params={"distance_m": 1.0},
    safety_approved=True,
))

print(f"Sealed: {record.content_hash[:12]}...")
print(f"Chain valid: {chain.verify_all()}")  # True

# Export JSONL for long-term storage or audit
with open("audit.jsonl", "w") as f:
    f.write(chain.to_jsonl())`} />

  <!-- Step 5 -->
  <h2 id="register">
    <span class="text-accent font-mono text-lg mr-2">05</span>Register Your Robot
  </h2>
  <p>Get a globally unique RRN (Robot Registry Number). Free.</p>
  <p class="text-sm text-text-muted mt-2">New RRNs use 12-digit sequences (e.g. <code>RRN-000000000001</code>). Legacy 8-digit RRNs (<code>RRN-00000001</code>) remain valid — the format is backward compatible.</p>

  <CodeWindow language="bash" title="Terminal" code={`# If using OpenCastor — built into the setup wizard
castor wizard
# → Step 13: Register with rcan.dev? [Y/n]  →  ✅ RRN-000000000042

# Or standalone
castor register --config myrobot.rcan.yaml`} />

  <!-- Step 5b: Federated Resolution -->
  <h2 id="federated-resolution">
    <span class="text-accent font-mono text-lg mr-2">05b</span>Federated Resolution
  </h2>
  <p>Any client can resolve an RRN across the federation — even if registered at a manufacturer's authoritative node:</p>

  <!-- NodeClient Tabs -->
  <div class="not-prose my-6">
    <div class="flex gap-2 mb-0 border-b border-white/10" id="node-tabs">
      <button class="node-tab px-4 py-2 text-sm font-medium rounded-t-lg border border-b-0 border-white/10 bg-accent/10 text-accent transition-all" data-ntab="node-python">Python</button>
      <button class="node-tab px-4 py-2 text-sm font-medium rounded-t-lg border border-b-0 border-white/10 bg-bg-alt/30 text-text-muted hover:text-white transition-all" data-ntab="node-typescript">TypeScript</button>
    </div>

    <div id="tab-node-python" class="node-panel rounded-b-lg rounded-tr-lg border border-white/10 bg-bg-alt/30 p-4 font-mono text-sm overflow-x-auto">
      <pre class="text-green-400">from rcan import NodeClient</pre>
      <pre class="text-white mt-2">client = NodeClient()</pre>
      <pre class="text-white mt-2"><span class="text-text-muted"># Resolve an RRN from any node in the federation</span></pre>
      <pre class="text-white">robot = client.resolve("RRN-BD-000000000001")</pre>
      <pre class="text-white">print(f"Found: &#123;robot['record']['name']&#125; (resolved by &#123;robot['resolved_by']&#125;)")</pre>
      <pre class="text-white mt-2"><span class="text-text-muted"># Discover which node is authoritative for a namespace</span></pre>
      <pre class="text-white">node = client.discover("RRN-BD-000000000001")</pre>
      <pre class="text-white">print(f"Authoritative node: &#123;node['operator']&#125; at &#123;node['api_base']&#125;")</pre>
      <pre class="text-white mt-2"><span class="text-text-muted"># List all known registry nodes</span></pre>
      <pre class="text-white">nodes = client.list_nodes()</pre>
      <pre class="text-white">for n in nodes:</pre>
      <pre class="text-white">    print(f"  &#123;n['operator']&#125;: &#123;n['namespace_prefix']&#125;")</pre>
    </div>

    <div id="tab-node-typescript" class="node-panel hidden rounded-b-lg rounded-tr-lg border border-white/10 bg-bg-alt/30 p-4 font-mono text-sm overflow-x-auto">
      <pre class="text-green-400">import &#123; NodeClient &#125; from '@continuonai/rcan-ts';</pre>
      <pre class="text-white mt-2">const client = new NodeClient();</pre>
      <pre class="text-white mt-2"><span class="text-text-muted">// Resolve across federation</span></pre>
      <pre class="text-white">const result = await client.resolve('RRN-BD-000000000001');</pre>
      <pre class="text-white">console.log(`Found: $&#123;result.record.name&#125; (via $&#123;result.resolved_by&#125;)`);</pre>
      <pre class="text-white mt-2"><span class="text-text-muted">// Verify a node manifest</span></pre>
      <pre class="text-white">const manifest = await client.getNodeManifest('https://registry.example.com');</pre>
      <pre class="text-white">const valid = client.verifyNode(manifest);</pre>
      <pre class="text-white">console.log(`Node valid: $&#123;valid&#125;`);</pre>
    </div>
  </div>

  <script>
    const nodeTabs = document.querySelectorAll<HTMLButtonElement>('.node-tab');
    const nodePanels = document.querySelectorAll<HTMLElement>('.node-panel');
    nodeTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.ntab;
        nodeTabs.forEach(t => {
          t.classList.toggle('bg-accent/10', t.dataset.ntab === target);
          t.classList.toggle('text-accent', t.dataset.ntab === target);
          t.classList.toggle('bg-bg-alt/30', t.dataset.ntab !== target);
          t.classList.toggle('text-text-muted', t.dataset.ntab !== target);
        });
        nodePanels.forEach(p => {
          p.classList.toggle('hidden', p.id !== `tab-${target}`);
        });
      });
    });
  </script>

  <!-- Step 6 -->
  <h2 id="validate">
    <span class="text-accent font-mono text-lg mr-2">06</span>Validate Your Config
  </h2>

  <CodeWindow language="bash" title="Terminal" code={`# Check L1/L2/L3 conformance
rcan-validate config myrobot.rcan.yaml

# Expected output:
# ✅ L1 — Addressing + message format: passed
# ✅ L2 — Auth + confidence gates: passed
# ⚠️  L3 — hitl_gates not configured (§16)
# Result: L2 (1 warning)

# Or with OpenCastor
castor compliance --config myrobot.rcan.yaml`} />

  <!-- What's Next -->
  <h2 id="next">What's next</h2>

  <div class="not-prose grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6">
    {[
      { href: '/spec/', label: 'Protocol Spec', desc: 'Full RCAN v1.2 specification' },
      { href: '/conformance/', label: 'Conformance Tests', desc: 'L1/L2/L3 test suite' },
      { href: 'https://github.com/continuonai/rcan-py', label: 'rcan-py on GitHub', desc: 'Python SDK source + issues' },
      { href: 'https://github.com/continuonai/rcan-ts', label: 'rcan-ts on GitHub', desc: 'TypeScript SDK source + issues' },
      { href: 'https://github.com/craigm26/OpenCastor', label: 'OpenCastor', desc: 'Robot runtime with RCAN built in' },
      { href: '/registry/submit/', label: 'Register a Robot', desc: 'Get your free RRN' },
    ].map(({ href, label, desc }) => (
      <a href={href} target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
        class="block p-4 border border-white/8 rounded-xl hover:border-accent/40 hover:bg-accent/5 transition-all duration-200">
        <div class="text-white font-semibold text-sm">{label}</div>
        <div class="text-text-muted text-xs mt-1">{desc}</div>
      </a>
    ))}
  </div>

</DocsLayout>
