---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Manufacturer dashboard — client-side only, uses API key stored in localStorage
// Fetches robots from /api/v1/robots using the stored key
---

<BaseLayout
  title="Manufacturer Dashboard"
  description="Manage your registered robots, view commitment chain stats, and update robot metadata."
>
  <div id="dashboard-root">

    <!-- Auth gate -->
    <div id="auth-gate" class="max-w-md mx-auto pt-12">
      <div class="bg-bg-alt border border-white/5 rounded-2xl p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center text-accent text-lg">🔑</div>
          <div>
            <h1 class="text-xl font-bold text-text">Manufacturer Dashboard</h1>
            <p class="text-sm text-text-muted">Enter your RCAN API key to continue</p>
          </div>
        </div>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-text-muted mb-1.5" for="api-key-input">API Key</label>
            <input
              id="api-key-input"
              type="password"
              placeholder="rcan_..."
              class="w-full bg-bg border border-white/10 rounded-lg px-3 py-2.5 text-text text-sm font-mono placeholder-text-muted/40 focus:outline-none focus:border-accent/50"
              autocomplete="off"
            />
          </div>
          <label class="flex items-center gap-2 text-sm text-text-muted cursor-pointer select-none">
            <input id="remember-key" type="checkbox" class="accent-cyan-400" checked />
            Remember key in this browser
          </label>
          <button
            id="auth-btn"
            class="w-full py-2.5 rounded-lg bg-accent text-bg text-sm font-semibold hover:bg-accent/90 transition-colors"
          >
            Sign in
          </button>
          <p class="text-xs text-text-muted text-center">
            No key yet? <a href="/registry/register/" class="text-accent hover:underline">Register your first robot →</a>
          </p>
        </div>
        <div id="auth-error" class="hidden mt-3 text-sm text-red-400"></div>
      </div>
    </div>

    <!-- Dashboard content (hidden until auth) -->
    <div id="dashboard-content" class="hidden">

      <!-- Header bar -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-bold text-text">Your Robots</h1>
          <p id="dash-subtitle" class="text-sm text-text-muted mt-0.5"></p>
        </div>
        <div class="flex items-center gap-3">
          <a href="/registry/register/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-accent text-bg text-sm font-semibold hover:bg-accent/90 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Register robot
          </a>
          <button id="sign-out-btn" class="px-3 py-2 rounded-lg border border-white/10 text-text-muted text-sm hover:border-white/20 transition-colors">Sign out</button>
        </div>
      </div>

      <!-- Stats bar -->
      <div id="stats-bar" class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
        {[
          { id: 'stat-total', label: 'Registered', icon: '🤖' },
          { id: 'stat-active', label: 'Active', icon: '✅' },
          { id: 'stat-tier', label: 'Verification', icon: '🛡️' },
          { id: 'stat-chain', label: 'Commitment records', icon: '🔗' },
        ].map(s => (
          <div class="bg-bg-alt border border-white/5 rounded-xl p-4">
            <div class="text-lg mb-1">{s.icon}</div>
            <div id={s.id} class="text-xl font-bold text-text">—</div>
            <div class="text-xs text-text-muted">{s.label}</div>
          </div>
        ))}
      </div>

      <!-- Robot grid -->
      <div id="robot-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>

      <!-- Empty state -->
      <div id="empty-state" class="hidden text-center py-20">
        <div class="text-4xl mb-4">🤖</div>
        <h2 class="text-xl font-bold text-text mb-2">No robots yet</h2>
        <p class="text-text-muted mb-6">Register your first robot to get a global RRN identity.</p>
        <a href="/registry/register/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-accent text-bg font-semibold text-sm hover:bg-accent/90 transition-colors">Register your first robot</a>
      </div>

      <!-- Edit modal -->
      <div id="edit-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-[#12121a] border border-white/10 rounded-2xl p-6 w-full max-w-lg">
          <h2 class="text-lg font-bold text-text mb-5">Edit robot</h2>
          <input id="edit-rrn" type="hidden" />
          <div class="space-y-4">
            <div>
              <label class="block text-sm text-text-muted mb-1">Display name</label>
              <input id="edit-name" type="text" class="w-full bg-bg border border-white/10 rounded-lg px-3 py-2 text-text text-sm focus:outline-none focus:border-accent/50" />
            </div>
            <div>
              <label class="block text-sm text-text-muted mb-1">Description</label>
              <textarea id="edit-desc" rows="3" class="w-full bg-bg border border-white/10 rounded-lg px-3 py-2 text-text text-sm resize-none focus:outline-none focus:border-accent/50"></textarea>
            </div>
            <div>
              <label class="block text-sm text-text-muted mb-1">Contact email</label>
              <input id="edit-contact" type="email" class="w-full bg-bg border border-white/10 rounded-lg px-3 py-2 text-text text-sm focus:outline-none focus:border-accent/50" />
            </div>
          </div>
          <div class="flex gap-3 mt-6">
            <button id="edit-save" class="flex-1 py-2.5 rounded-lg bg-accent text-bg text-sm font-semibold hover:bg-accent/90 transition-colors">Save</button>
            <button id="edit-cancel" class="px-5 py-2.5 rounded-lg border border-white/10 text-text-muted text-sm hover:border-white/20 transition-colors">Cancel</button>
          </div>
          <div id="edit-error" class="hidden mt-3 text-sm text-red-400"></div>
        </div>
      </div>

    </div>

  </div>
</BaseLayout>

<script>
const API_BASE = "/api/v1/robots";
const KEY_STORE = "rcan_api_key";

let apiKey = "";

// ── Helpers ──────────────────────────────────────────────────────────────────

function $(id: string) { return document.getElementById(id)!; }

function showEl(id: string) { $(id).classList.remove("hidden"); }
function hideEl(id: string) { $(id).classList.add("hidden"); }

async function apiFetch(path: string, options: RequestInit = {}) {
  const res = await fetch(path, {
    ...options,
    headers: {
      "Content-Type": "application/json",
      "x-api-key": apiKey,
      ...(options.headers || {}),
    },
  });
  if (!res.ok) {
    const text = await res.text().catch(() => "");
    throw new Error(`${res.status}: ${text || res.statusText}`);
  }
  return res.json();
}

// ── Robot card HTML ───────────────────────────────────────────────────────────

function robotCard(r: any) {
  const tierEmoji: Record<string, string> = { community: "⬜", verified: "🟡", manufacturer: "🔵", certified: "✅" };
  const badge = tierEmoji[r.verification_tier ?? "community"] ?? "⬜";
  return `
    <div class="bg-bg-alt border border-white/5 rounded-xl p-5 flex flex-col gap-3 hover:border-accent/20 transition-colors">
      <div class="flex items-start justify-between gap-2">
        <div>
          <div class="flex items-center gap-2">
            <span class="font-mono text-xs text-accent">${r.rrn}</span>
            <span title="${r.verification_tier ?? 'community'}">${badge}</span>
          </div>
          <h3 class="font-semibold text-text mt-1">${r.name ?? `${r.manufacturer} ${r.model}`}</h3>
          <p class="text-xs text-text-muted">${r.manufacturer} · ${r.model} · ${r.version}</p>
        </div>
        <span class="text-xs px-2 py-0.5 rounded-full border ${r.status === 'active' ? 'bg-green-500/10 text-green-400 border-green-500/20' : 'bg-white/5 text-text-muted border-white/10'}">${r.status ?? 'active'}</span>
      </div>
      ${r.description ? `<p class="text-sm text-text-muted line-clamp-2">${r.description}</p>` : ""}
      <div class="font-mono text-xs text-text-muted/60 bg-bg rounded-lg px-3 py-2 truncate">rcan://${r.rrn_uri ?? `registry.rcan.dev/${r.manufacturer}/${r.model}/${r.version}/${r.device_id}`}</div>
      <div class="flex gap-2 mt-auto">
        <button onclick="openEdit('${r.rrn}')" data-robot='${JSON.stringify(r).replace(/'/g, "&#39;")}' class="flex-1 py-1.5 rounded-lg border border-white/10 text-text-muted text-xs hover:border-accent/30 hover:text-accent transition-colors">Edit</button>
        <a href="/registry/${r.rrn}/" class="flex-1 py-1.5 rounded-lg border border-white/10 text-text-muted text-xs text-center hover:border-white/20 transition-colors">View</a>
      </div>
    </div>`;
}

// ── Load dashboard ────────────────────────────────────────────────────────────

async function loadDashboard() {
  try {
    const data = await apiFetch(`${API_BASE}?limit=100`);
    const robots = data.robots ?? data.results ?? [];

    $("stat-total").textContent = String(robots.length);
    $("stat-active").textContent = String(robots.filter((r: any) => r.status === "active").length);

    const tiers = [...new Set(robots.map((r: any) => r.verification_tier ?? "community"))];
    const topTier = tiers.includes("certified") ? "✅ Certified" :
                    tiers.includes("manufacturer") ? "🔵 Manufacturer" :
                    tiers.includes("verified") ? "🟡 Verified" : "⬜ Community";
    $("stat-tier").textContent = topTier;
    $("stat-chain").textContent = robots.reduce((n: number, r: any) => n + (r.commitment_count ?? 0), 0).toString();

    $("dash-subtitle").textContent = `${robots.length} robot${robots.length !== 1 ? "s" : ""} registered`;

    const grid = $("robot-grid");
    if (robots.length === 0) {
      showEl("empty-state");
    } else {
      grid.innerHTML = robots.map(robotCard).join("");
      hideEl("empty-state");
    }
  } catch (e: any) {
    $("dash-subtitle").textContent = `Error loading: ${e.message}`;
  }
}

// ── Edit modal ────────────────────────────────────────────────────────────────

(window as any).openEdit = function(rrn: string) {
  const btn = document.querySelector(`[onclick="openEdit('${rrn}')"]`) as HTMLElement;
  const robot = JSON.parse(btn?.dataset.robot ?? "{}");
  ($("edit-rrn") as HTMLInputElement).value = rrn;
  ($("edit-name") as HTMLInputElement).value = robot.name ?? "";
  ($("edit-desc") as HTMLTextAreaElement).value = robot.description ?? "";
  ($("edit-contact") as HTMLInputElement).value = robot.contact_email ?? "";
  hideEl("edit-error");
  showEl("edit-modal");
};

$("edit-cancel").addEventListener("click", () => hideEl("edit-modal"));

$("edit-save").addEventListener("click", async () => {
  const rrn = ($("edit-rrn") as HTMLInputElement).value;
  const body = {
    name: ($("edit-name") as HTMLInputElement).value,
    description: ($("edit-desc") as HTMLTextAreaElement).value,
    contact_email: ($("edit-contact") as HTMLInputElement).value,
  };
  try {
    await apiFetch(`${API_BASE}/${rrn}`, { method: "PATCH", body: JSON.stringify(body) });
    hideEl("edit-modal");
    loadDashboard();
  } catch (e: any) {
    showEl("edit-error");
    $("edit-error").textContent = e.message;
  }
});

// ── Auth ──────────────────────────────────────────────────────────────────────

function doSignIn(key: string) {
  apiKey = key;
  hideEl("auth-gate");
  showEl("dashboard-content");
  loadDashboard();
}

// Auto-sign-in if key saved
const savedKey = localStorage.getItem(KEY_STORE);
if (savedKey) { doSignIn(savedKey); }

$("auth-btn").addEventListener("click", async () => {
  const key = ($("api-key-input") as HTMLInputElement).value.trim();
  if (!key) { return; }
  try {
    await apiFetch(`${API_BASE}?limit=1`, {
      headers: { "Content-Type": "application/json", "x-api-key": key },
    });
    if (($("remember-key") as HTMLInputElement).checked) {
      localStorage.setItem(KEY_STORE, key);
    }
    doSignIn(key);
  } catch (e: any) {
    showEl("auth-error");
    $("auth-error").textContent = "Invalid API key — check and try again.";
  }
});

$("api-key-input").addEventListener("keydown", (e) => {
  if (e.key === "Enter") ($("auth-btn") as HTMLButtonElement).click();
});

$("sign-out-btn").addEventListener("click", () => {
  apiKey = "";
  localStorage.removeItem(KEY_STORE);
  ($("api-key-input") as HTMLInputElement).value = "";
  hideEl("dashboard-content");
  showEl("auth-gate");
});
</script>
