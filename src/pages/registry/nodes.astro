---
import Layout from '../../layouts/BaseLayout.astro';

const knownNodes = [
  {
    operator: "Robot Registry Foundation",
    node_type: "root",
    namespace_prefix: "RRN",
    api_base: "https://rcan.dev/api/v1",
    capabilities: ["register", "resolve", "verify", "delegate"],
    manifest_url: "/.well-known/rcan-node.json",
    status: "live",
    spec_version: "1.2",
  }
];
---

<Layout title="Registry Nodes — RCAN" description="Federated RCAN registry nodes powering the Robot Registry Network.">
  <main class="min-h-screen bg-[#0a0a0f] text-white">

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-6 pt-32 pb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-cyan-400/20 bg-cyan-400/5 text-cyan-400 text-xs font-mono mb-6">
        <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 animate-pulse"></span>
        Federated Infrastructure
      </div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
        Registry <span class="text-cyan-400">Nodes</span>
      </h1>
      <p class="text-lg text-white/60 max-w-2xl leading-relaxed">
        The RCAN registry is a federated network of nodes. Each node is an authoritative
        source for its namespace prefix, enabling decentralised robot identity across
        the Robot Registry Network.
      </p>
    </section>

    <!-- Architecture note -->
    <section class="max-w-5xl mx-auto px-6 pb-12">
      <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6">
        <h2 class="text-sm font-mono text-cyan-400 uppercase tracking-widest mb-3">Federation Architecture</h2>
        <p class="text-white/60 text-sm leading-relaxed">
          Registry nodes implement the RCAN Federation Protocol (see
          <a href="/federation/" class="text-cyan-400 hover:underline">/federation/</a>).
          Each node exposes a <code class="font-mono text-xs bg-white/10 px-1.5 py-0.5 rounded">/.well-known/rcan-node.json</code>
          manifest describing its capabilities, operator, and sync endpoint. Root nodes anchor
          the namespace hierarchy; authoritative nodes own sub-prefixes; resolver and cache nodes
          provide high-availability read access.
        </p>
      </div>
    </section>

    <!-- Node cards -->
    <section class="max-w-5xl mx-auto px-6 pb-16">
      <h2 class="text-xl font-semibold mb-6">Known Nodes</h2>
      <div class="grid gap-4">
        {knownNodes.map(node => (
          <div class="rounded-xl border border-white/10 bg-white/[0.03] p-6 hover:border-cyan-400/30 transition-colors">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3 flex-wrap">
                  <h3 class="text-lg font-semibold text-white">{node.operator}</h3>
                  <span class:list={[
                    "px-2 py-0.5 rounded text-xs font-mono font-bold uppercase",
                    node.node_type === "root"
                      ? "bg-cyan-400/15 text-cyan-400 border border-cyan-400/30"
                      : "bg-white/10 text-white/60 border border-white/10"
                  ]}>
                    {node.node_type}
                  </span>
                  <span class:list={[
                    "px-2 py-0.5 rounded text-xs font-mono",
                    node.status === "live"
                      ? "bg-emerald-500/10 text-emerald-400 border border-emerald-500/20"
                      : "bg-white/5 text-white/40 border border-white/10"
                  ]} id={`status-${node.namespace_prefix}`}>
                    {node.status}
                  </span>
                </div>

                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-2 text-sm mb-4">
                  <div class="flex gap-2">
                    <dt class="text-white/40 shrink-0">Namespace</dt>
                    <dd class="font-mono text-white/80">{node.namespace_prefix}</dd>
                  </div>
                  <div class="flex gap-2">
                    <dt class="text-white/40 shrink-0">Spec</dt>
                    <dd class="font-mono text-white/80">v{node.spec_version}</dd>
                  </div>
                  <div class="flex gap-2 sm:col-span-2">
                    <dt class="text-white/40 shrink-0">API Base</dt>
                    <dd class="font-mono text-cyan-400/80 text-xs break-all">{node.api_base}</dd>
                  </div>
                </dl>

                <div class="flex flex-wrap gap-1.5 mb-4">
                  {node.capabilities.map(cap => (
                    <span class="px-2 py-0.5 rounded bg-white/5 border border-white/10 text-white/50 text-xs font-mono">
                      {cap}
                    </span>
                  ))}
                </div>
              </div>

              <div class="flex flex-col gap-2 shrink-0">
                <a
                  href={node.manifest_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-2 px-4 py-2 rounded-lg border border-cyan-400/30 bg-cyan-400/5 text-cyan-400 text-sm hover:bg-cyan-400/10 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                  </svg>
                  View manifest
                </a>
              </div>
            </div>

            <!-- Live status (populated by client JS) -->
            <div id={`live-${node.namespace_prefix}`} class="mt-2 text-xs text-white/30 font-mono hidden">
              Fetching live status…
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA: Run your own node -->
    <section class="max-w-5xl mx-auto px-6 pb-16">
      <div class="rounded-xl border border-white/10 bg-gradient-to-br from-cyan-400/5 to-white/[0.02] p-8">
        <h2 class="text-2xl font-bold mb-3">Run Your Own Node</h2>
        <p class="text-white/60 mb-6 max-w-xl">
          Organisations can operate authoritative RCAN registry nodes for their own namespace
          prefixes. Node registration is currently manual via the governance process.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/federation/"
            class="px-5 py-2.5 rounded-lg bg-cyan-400 text-black font-semibold text-sm hover:bg-cyan-300 transition-colors"
          >
            Federation docs
          </a>
          <a
            href="/governance/"
            class="px-5 py-2.5 rounded-lg border border-white/20 text-white/70 font-semibold text-sm hover:border-white/40 hover:text-white transition-colors"
          >
            Governance process
          </a>
        </div>
        <p class="mt-6 text-xs text-white/30">
          Node registration is currently a manual process coordinated through the RCAN
          governance board. Automated federation onboarding is planned for a future spec revision.
        </p>
      </div>
    </section>

  </main>
</Layout>

<script>
  // Fetch live node status from /.well-known/rcan-node.json
  async function fetchNodeStatus() {
    const el = document.getElementById('live-RRN');
    const statusEl = document.getElementById('status-RRN');
    if (!el) return;

    el.classList.remove('hidden');
    el.textContent = 'Fetching live status…';

    try {
      const res = await fetch('/.well-known/rcan-node.json');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      el.classList.add('text-white/40');
      el.classList.remove('text-white/30');
      el.textContent = `live · last_sync: ${data.last_sync ?? 'n/a'} · ttl: ${data.ttl_seconds ?? 'n/a'}s · key: ${(data.public_key ?? '').slice(0, 28)}…`;

      if (statusEl) {
        statusEl.textContent = 'live';
        statusEl.classList.add('bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
      }
    } catch (err) {
      el.textContent = `manifest fetch failed: ${err instanceof Error ? err.message : String(err)}`;
      if (statusEl) {
        statusEl.textContent = 'unknown';
        statusEl.classList.remove('bg-emerald-500/10', 'text-emerald-400', 'border-emerald-500/20');
        statusEl.classList.add('bg-white/5', 'text-white/40', 'border-white/10');
      }
    }
  }

  fetchNodeStatus();
</script>
