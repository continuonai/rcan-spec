---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Verification Tiers — RCAN Robot Registry";
const description = "How RCAN verifies robot manufacturers: four tiers from community self-attestation to third-party certification.";

const tiers = [
  {
    emoji: "⬜",
    name: "Community",
    slug: "community",
    label: "Self-attested",
    color: "text-text-muted",
    borderColor: "border-white/10",
    bgColor: "bg-white/3",
    iconBg: "bg-white/5",
    requirements: [
      "Valid manufacturer + model + version + device ID",
      "Unique RRN assigned automatically",
      "rcan_uri resolvable at rcan.dev",
      "No verification performed",
    ],
    who: "Hobbyists, researchers, small teams, early-stage startups",
    howToGet: "Register at rcan.dev/registry/register — instant, free.",
    limitations: [
      "Not suitable for EU AI Act Art. 49 compliance",
      "Not suitable for safety-critical deployments",
    ],
  },
  {
    emoji: "🟡",
    name: "Verified",
    slug: "verified",
    label: "Email + domain verified",
    color: "text-yellow-400",
    borderColor: "border-yellow-500/30",
    bgColor: "bg-yellow-500/5",
    iconBg: "bg-yellow-500/10",
    requirements: [
      "All Community requirements",
      "Verified email address",
      "Domain ownership verified (DNS TXT record)",
      "Company/org name matches domain registrant",
    ],
    who: "SMEs, university robotics labs, established hobbyist orgs",
    howToGet: "Coming soon — email verify@rcan.dev with domain details.",
    limitations: [
      "Not a legal entity verification",
      "Not suitable for regulated markets (medical, defense)",
    ],
  },
  {
    emoji: "🔵",
    name: "Manufacturer",
    slug: "manufacturer",
    label: "Legal entity verified",
    color: "text-blue-400",
    borderColor: "border-blue-500/30",
    bgColor: "bg-blue-500/5",
    iconBg: "bg-blue-500/10",
    requirements: [
      "All Verified requirements",
      "Legal entity documentation (DUNS, EIN, company registration)",
      "Authorized signatory approval",
      "Manufacturer agreement signed",
      "Annual renewal",
    ],
    who: "Commercial robot manufacturers, integrators with deployed fleets",
    howToGet: "Contact manufacturers@rcan.dev — manual review, ~5 business days.",
    limitations: [
      "Does not imply product safety certification",
      "Does not constitute EU CE marking",
    ],
  },
  {
    emoji: "✅",
    name: "Certified",
    slug: "certified",
    label: "Third-party conformance certified",
    color: "text-emerald-400",
    borderColor: "border-emerald-500/30",
    bgColor: "bg-emerald-500/5",
    iconBg: "bg-emerald-500/10",
    requirements: [
      "All Manufacturer requirements",
      "Third-party RCAN conformance test (L1/L2/L3)",
      "ISO 10218 or EU AI Act risk classification documented",
      "SBOM provided (CycloneDX JSON or SPDX)",
      "Commitment chain enabled (§16 AI accountability)",
      "Annual conformance renewal",
    ],
    who: "Manufacturers targeting regulated markets (EU AI Act, ISO 10218, medical, defense)",
    howToGet: "Contact certified@rcan.dev — schedule third-party conformance audit.",
    limitations: [],
  },
];
---

<BaseLayout title={title} description={description}>
  <div class="max-w-4xl mx-auto py-12">

    <div class="mb-12 text-center">
      <span class="text-xs font-mono text-accent/60 uppercase tracking-widest">Registry</span>
      <h1 class="text-3xl md:text-4xl font-bold text-white mt-2 mb-4">Verification Tiers</h1>
      <p class="text-xl text-text-muted max-w-2xl mx-auto">
        Four tiers of identity verification — from self-attested community registrations
        to third-party certified manufacturers. Each tier is visible on every robot's
        public registry page.
      </p>
    </div>

    <!-- Tier cards -->
    <div class="space-y-5 mb-16">
      {tiers.map((tier, i) => (
        <div class={`border rounded-2xl p-6 md:p-8 ${tier.borderColor} ${tier.bgColor}`} id={tier.slug}>
          <div class="flex flex-col md:flex-row md:items-start gap-6">
            <!-- Icon + badge -->
            <div class="flex-shrink-0 flex items-center gap-4 md:flex-col md:items-center md:gap-2">
              <div class={`w-14 h-14 rounded-xl ${tier.iconBg} border ${tier.borderColor} flex items-center justify-center text-2xl`}>
                {tier.emoji}
              </div>
              <div class="text-center">
                <div class={`text-lg font-bold ${tier.color}`}>{tier.name}</div>
                <div class="text-xs text-text-muted mt-0.5">{tier.label}</div>
              </div>
            </div>

            <!-- Details -->
            <div class="flex-1">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted/50 mb-3">Requirements</h3>
                  <ul class="space-y-1.5">
                    {tier.requirements.map(req => (
                      <li class="flex items-start gap-2 text-sm text-text-muted">
                        <span class={`mt-0.5 flex-shrink-0 ${tier.color}`}>✓</span>
                        {req}
                      </li>
                    ))}
                  </ul>
                </div>
                <div class="space-y-5">
                  <div>
                    <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted/50 mb-2">Who is this for</h3>
                    <p class="text-sm text-text-muted">{tier.who}</p>
                  </div>
                  <div>
                    <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted/50 mb-2">How to get it</h3>
                    <p class={`text-sm ${tier.color}`}>{tier.howToGet}</p>
                  </div>
                  {tier.limitations.length > 0 && (
                    <div>
                      <h3 class="text-xs font-semibold uppercase tracking-widest text-text-muted/50 mb-2">Limitations</h3>
                      <ul class="space-y-1">
                        {tier.limitations.map(lim => (
                          <li class="text-xs text-text-muted/60 flex items-start gap-1.5">
                            <span class="mt-0.5">⚠️</span>
                            {lim}
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Tier comparison table -->
    <section class="mb-16">
      <h2 class="text-xl font-bold text-white mb-6">At a Glance</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left py-3 pr-4 text-text-muted font-medium">Capability</th>
              {tiers.map(t => (
                <th class="text-center py-3 px-3 font-medium">
                  <span class={t.color}>{t.emoji} {t.name}</span>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {[
              { label: "Free RRN", values: [true, true, true, true] },
              { label: "Resolvable rcan:// URI", values: [true, true, true, true] },
              { label: "Email verified", values: [false, true, true, true] },
              { label: "Legal entity verified", values: [false, false, true, true] },
              { label: "L1/L2/L3 conformance cert", values: [false, false, false, true] },
              { label: "SBOM on file", values: [false, false, false, true] },
              { label: "EU AI Act Art. 49 ready", values: [false, false, true, true] },
              { label: "ISO 10218 ready", values: [false, false, false, true] },
            ].map(row => (
              <tr class="border-b border-white/5 hover:bg-white/2 transition-colors">
                <td class="py-3 pr-4 text-text-muted">{row.label}</td>
                {row.values.map(val => (
                  <td class="text-center py-3 px-3">
                    {val
                      ? <span class="text-emerald-400 font-bold">✓</span>
                      : <span class="text-white/15">—</span>
                    }
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- CTA -->
    <section class="text-center bg-accent/5 border border-accent/20 rounded-2xl p-10">
      <h2 class="text-2xl font-bold text-white mb-3">Start with Community — upgrade anytime</h2>
      <p class="text-text-muted mb-8 max-w-md mx-auto">
        Register your robot for free in under 60 seconds. No credit card, no approval required.
        You can apply for a higher tier at any time.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/registry/submit/" class="px-7 py-3.5 bg-accent text-bg font-bold rounded-full hover:bg-accent-hover transition-colors shadow-[0_0_20px_-5px_rgba(34,211,238,0.5)]">
          Register a Robot (Free)
        </a>
        <a href="/registry/" class="px-7 py-3.5 bg-white/5 border border-white/10 text-text font-semibold rounded-full hover:bg-white/10 transition-colors">
          Browse Registry
        </a>
      </div>
    </section>

  </div>
</BaseLayout>
