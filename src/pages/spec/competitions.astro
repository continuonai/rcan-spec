const seasonStandingExample = `{
  "version": "1.10.0",
  "message_id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
  "source_ruri": "rcan://cloud.castor.ai/standings",
  "target_ruri": "broadcast",
  "type": 39,
  "priority": 2,
