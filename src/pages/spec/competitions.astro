      {"rank": 2, "rrn": "RRN-000000000005", "score": 0.8812, "badge": "silver"},
      {"rank": 3, "rrn": "RRN-000000000012", "score": 0.8503, "badge": "bronze"}
    ],
    "days_remaining": 9
  }
