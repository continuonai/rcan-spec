---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';

const invokeMessage = `{
  "type": "INVOKE",
  "skill": "pick_and_place",
  "params": {
    "target": "red_cube"
  },
  "timeout_ms": 5000,
  "msg_id": "invoke_abc123"
}`;

const invokeResult = `{
  "type": "INVOKE_RESULT",
  "skill": "pick_and_place",
  "status": "success",
  "reply_to": "invoke_abc123",
  "duration_ms": 1230
}`;

const invokeFailure = `{
  "type": "INVOKE_RESULT",
  "skill": "pick_and_place",
  "status": "failure",
  "reply_to": "invoke_abc123",
  "duration_ms": 312,
  "error": {
    "code": 7006,
    "name": "SkillFailed",
    "message": "Gripper could not secure the target object"
  }
}`;

const invokeNotFound = `{
  "type": "INVOKE_RESULT",
  "skill": "undefined_skill",
  "status": "not_found",
  "reply_to": "invoke_xyz999",
  "error": {
    "code": 7001,
    "name": "SkillNotFound",
    "message": "No skill registered with name 'undefined_skill'"
  }
}`;

const invokeCancel = `{
  "type": "INVOKE_CANCEL",
  "payload": {
    "msg_id": "abc-123",
    "reason": "User aborted navigation task",
    "cancel_timeout_ms": 5000
  }
}`;

const invokeCancelledResult = `{
  "type": "INVOKE_RESULT",
  "skill": "navigate",
  "status": "cancelled",
  "reply_to": "abc-123",
  "duration_ms": 812,
  "error": {
    "code": 7007,
    "name": "SkillCancelled",
    "message": "Skill aborted by client INVOKE_CANCEL"
  }
}`;
---

<DocsLayout title="§19 Behavior/Skill Invocation Protocol" description="RCAN §19 — Behavior/Skill Invocation Protocol. Defines the INVOKE, INVOKE_RESULT, and INVOKE_CANCEL message types, status values, error codes, and integration with the Capability Advertisement Protocol.">
  <div class="flex items-center gap-4 mb-4">
    <h1 class="mb-0">§19 Behavior/Skill Invocation Protocol</h1>
