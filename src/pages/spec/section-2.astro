---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';

const roles = [
  { role: 'M2M_TRUSTED', level: '6',   rateLimit: 'Unlimited', ttl: '24 h max', perms: 'Fleet orchestration: RRF-issued only, cross-fleet COMMAND/INVOKE/CONFIG, no safety bypass' },
  { role: 'CREATOR',     level: '5',   rateLimit: 'Unlimited', ttl: 'None',     perms: 'Full hardware/software control, OTA push, safety override' },
  { role: 'M2M_PEER',    level: '4',   rateLimit: 'Unlimited', ttl: 'None',     perms: 'Robot-to-robot: authorized by ADMIN, can issue COMMAND/INVOKE to fleet peers' },
  { role: 'ADMIN',       level: '3',   rateLimit: '1000/min',  ttl: '8 h',      perms: 'Configuration, skill installation, user management, M2M_PEER authorization' },
  { role: 'OPERATOR',    level: '2',   rateLimit: '100/min',   ttl: '2 h',      perms: 'Operational control within allowed modes' },
  { role: 'CONTRIBUTOR', level: '2.5', rateLimit: '200/min',   ttl: '4 h',      perms: 'Idle compute contribution scope only (CONTRIBUTE_REQUEST/RESULT/CANCEL)' },
  { role: 'GUEST',       level: '1',   rateLimit: '10/min',    ttl: '5 min',    perms: 'Status viewing, read-only telemetry, text chat' },
];

const scopes = [
  { scope: 'status',        minRole: 'GUEST',       grants: 'Read health, telemetry, sensor data' },
  { scope: 'control',       minRole: 'OPERATOR',    grants: 'Issue commands, drive motors, run behaviors' },
  { scope: 'contribute',    minRole: 'CONTRIBUTOR', grants: 'Donate idle compute: CONTRIBUTE_REQUEST, CONTRIBUTE_RESULT, CONTRIBUTE_CANCEL' },
  { scope: 'config',        minRole: 'ADMIN',       grants: 'Modify RCAN config, reload, OTA' },
  { scope: 'training',      minRole: 'ADMIN',       grants: 'Submit episodes, trigger learner, export data' },
  { scope: 'authority',     minRole: 'ADMIN',       grants: 'Respond to AUTHORITY_ACCESS (41) requests, FIRMWARE_ATTESTATION (43), SBOM_UPDATE (44)' },
  { scope: 'admin',         minRole: 'CREATOR',     grants: 'Safety overrides, hardware resets, key rotation' },
  { scope: 'fleet.trusted', minRole: 'M2M_TRUSTED', grants: 'Cross-fleet COMMAND/INVOKE/CONFIG without per-robot CREATOR approval. RRF-issued tokens only.' },
];

const gatewayRoles = [
  { gw: 'admin',    rcan: 'ADMIN (3)',    scopes: 'status, control, config, training' },
  { gw: 'operator', rcan: 'OPERATOR (2)', scopes: 'status, control' },
  { gw: 'viewer',   rcan: 'GUEST (1)',    scopes: 'status' },
];

const m2mNote = `# M2M_PEER authorization flow
# 1. An ADMIN issues an M2M authorization token for a specific peer robot
POST /api/m2m/authorize
{ "peer_rrn": "RRN-000000000005", "scopes": ["control", "status"], "expires_at": 1800 }

# 2. The peer robot carries this token in its JWT auth_token field
# 3. The receiving robot validates the M2M token against its ADMIN's public key
# 4. P66 safety invariant: M2M ESTOP is ALWAYS honored regardless of M2M role level`;

const m2mTrustedNote = `# M2M_TRUSTED authorization flow
# 1. CREATOR registers an orchestration system with RRF, supplying its public key
POST https://api.rrf.rcan.dev/v2/orchestrators/register
{ "rrn": "RRN-000000000001", "orchestrator_key": "<ed25519-pubkey>", "justification": "Fleet brain" }

# 2. RRF validates the CREATOR's identity and issues a time-limited M2M_TRUSTED token
#    signed by the RRF root key (NOT by the CREATOR or any robot)
GET https://api.rrf.rcan.dev/v2/orchestrators/RRN-000000000001/token
→ { "token": "<jwt>", "rcan_role": "m2m_trusted", "scopes": ["fleet.trusted"], "exp": 86400 }

# 3. The orchestration system presents this token in every message envelope
# 4. Receiving robots verify the token against the RRF root public key
#    (published at https://api.rrf.rcan.dev/.well-known/rrf-root-pubkey.pem)

# HARD LIMITS — enforced in protocol, cannot be overridden by token claims:
# - ESTOP (Priority.SAFETY) from any principal is ALWAYS honored
# - M2M_TRUSTED may NOT issue tokens to other principals
# - M2M_TRUSTED tokens are scoped to a single registered orchestrator key
# - Token revocation is immediate: RRF revocation list is checked on every verify`;
---

<DocsLayout title="§2 Role-Based Access Control" description="RCAN §2 — Role-Based Access Control. Defines the five-level role hierarchy, fine-grained scopes, and gateway role mapping.">
