---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';

const friaSchema = `{
  "schema": "rcan-fria-v1",
  "spec_ref": "https://rcan.dev/spec/section-22",
  "generated_at": "2026-04-10T14:32:01.123Z",
  "system": {
    "rrn": "RRN-000000000001",
    "rrn_uri": "rrn://org/robot/model/id",
    "robot_name": "my-robot",
    "opencastor_version": "2026.4.10.0",
    "rcan_version": "1.9.0",
    "agent_provider": "anthropic",
    "agent_model": "claude-sonnet-4-6"
  },
  "deployment": {
    "annex_iii_basis": "safety_component",
    "intended_use": "indoor autonomous navigation",
    "prerequisite_waived": false
  },
  "conformance": {
    "score": 87,
    "pass": 24,
    "warn": 2,
    "fail": 0,
    "checks": [
      { "check_id": "safety.estop_configured", "category": "safety", "status": "pass", "detail": "ESTOP configured" }
    ]
  },
  "human_oversight": {
    "hitl_configured": true,
    "confidence_gates_configured": true,
    "estop_configured": true
  },
  "hardware_observations": [
    { "id": "mem-abc01", "text": "Left motor stalls at 50% duty under load", "confidence": 0.82, "tags": ["motor"] }
  ],
  "signing_key": {
    "alg": "ml-dsa-65",
    "kid": "rpi5-key-001",
    "public_key": "<base64url ML-DSA-65 public key>"
  },
  "sig": {
    "alg": "ml-dsa-65",
    "kid": "rpi5-key-001",
    "value": "<base64url signature>"
  }
}`;

const cliExample = `# Generate FRIA for a safety-critical deployment
castor fria generate \\
  --config bob.rcan.yaml \\
  --annex-iii safety_component \\
  --intended-use "Indoor autonomous navigation" \\
  --output fria-bob-2026.json

# Output:
# FRIA artifact: fria-bob-2026.json
# HTML companion: fria-bob-2026.html`;

const prerequisiteExample = `# Conformance gate blocks generation when score < 80 or safety failures exist:
$ castor fria generate --config bot.yaml --annex-iii safety_component
FRIA generation blocked — conformance gaps must be resolved:
  [safety.estop_configured] Emergency stop not configured
    Fix: Set safety.emergency_stop in config

Use --force to generate despite conformance gaps.`;

const fields = [
  { field: 'schema',                    type: 'string',  req: 'MUST', desc: 'Always "rcan-fria-v1". Identifies document type.' },
  { field: 'spec_ref',                  type: 'string',  req: 'MUST', desc: 'Always "https://rcan.dev/spec/section-22". Provides stable citation URL for notified bodies.' },
  { field: 'generated_at',              type: 'string',  req: 'MUST', desc: 'ISO-8601 UTC timestamp of document generation.' },
  { field: 'system.rrn',                type: 'string',  req: 'MUST', desc: 'Robot Registration Number (RRN). Must match config metadata.rrn.' },
  { field: 'system.rrn_uri',            type: 'string',  req: 'SHOULD', desc: 'RRN URI form (rrn://org/category/model/id). Recommended for §21 registry lookup.' },
  { field: 'system.robot_name',         type: 'string',  req: 'MUST', desc: 'Human-readable robot name from config.' },
  { field: 'system.opencastor_version', type: 'string',  req: 'MUST', desc: 'Runtime version that generated this document.' },
  { field: 'system.rcan_version',       type: 'string',  req: 'MUST', desc: 'RCAN protocol version the robot implements.' },
  { field: 'system.agent_provider',     type: 'string',  req: 'MUST', desc: 'AI provider (e.g. "anthropic", "google").' },
  { field: 'system.agent_model',        type: 'string',  req: 'MUST', desc: 'AI model identifier.' },
  { field: 'deployment.annex_iii_basis',type: 'string',  req: 'MUST', desc: 'EU AI Act Annex III classification basis. See valid values below.' },
  { field: 'deployment.intended_use',   type: 'string',  req: 'MUST', desc: 'Free-text description of the deployment context.' },
  { field: 'deployment.prerequisite_waived', type: 'boolean', req: 'MUST', desc: 'True if the conformance gate was bypassed with --force. Notified bodies must treat waived documents as provisional.' },
  { field: 'conformance.score',         type: 'integer', req: 'MUST', desc: 'Conformance score (0–100). Must be ≥ 80 for L2+ deployments unless prerequisite_waived.' },
  { field: 'conformance.pass/warn/fail',type: 'integer', req: 'MUST', desc: 'Count of checks by status.' },
  { field: 'conformance.checks',        type: 'array',   req: 'MUST', desc: 'Full list of ConformanceResult entries with check_id, category, status, detail, fix (if applicable).' },
  { field: 'human_oversight.hitl_configured',                type: 'boolean', req: 'MUST', desc: 'True if HiTL authorization gates are enabled (§8).' },
  { field: 'human_oversight.confidence_gates_configured',    type: 'boolean', req: 'MUST', desc: 'True if per-scope confidence thresholds are set (§16.2).' },
  { field: 'human_oversight.estop_configured',               type: 'boolean', req: 'MUST', desc: 'True if emergency stop is configured.' },
  { field: 'hardware_observations',     type: 'array',   req: 'SHOULD', desc: 'HARDWARE_OBSERVATION entries from robot memory with confidence ≥ 0.30. Supports Art. 17 quality management evidence.' },
  { field: 'signing_key',              type: 'object',  req: 'SHOULD', desc: 'ML-DSA-65 public key reference. Required for L2+ deployments. Omitted when --skip-sign is used.' },
  { field: 'sig',                      type: 'object',  req: 'SHOULD', desc: 'ML-DSA-65 signature over canonical JSON (sort_keys, no whitespace, sig field absent). Required for L2+ deployments.' },
];

const annexIiiBases = [
  { value: 'safety_component',         article: 'Annex III §1', desc: 'Safety components of products covered by Union harmonisation legislation' },
  { value: 'biometric',                article: 'Annex III §2', desc: 'Biometric identification and categorisation' },
  { value: 'critical_infrastructure',  article: 'Annex III §3', desc: 'Critical infrastructure management and operation' },
  { value: 'education',                article: 'Annex III §4', desc: 'Education and vocational training' },
  { value: 'employment',               article: 'Annex III §5', desc: 'Employment, workers management and access to self-employment' },
  { value: 'essential_services',       article: 'Annex III §6', desc: 'Access to and enjoyment of essential private services and public services and benefits' },
  { value: 'law_enforcement',          article: 'Annex III §7', desc: 'Law enforcement' },
  { value: 'migration',                article: 'Annex III §8', desc: 'Migration, asylum and border control management' },
  { value: 'administration_of_justice',article: 'Annex III §9', desc: 'Administration of justice and democratic processes' },
  { value: 'general_purpose_ai',       article: 'Annex III §10', desc: 'General-purpose AI systems' },
];

const euMapping = [
  { fria: 'conformance block',       article: 'Art. 9',      desc: 'Risk management system — conformance score and check evidence' },
  { fria: 'system block',            article: 'Art. 13',     desc: 'Transparency — system identity, model, provider' },
  { fria: 'human_oversight block',   article: 'Art. 14',     desc: 'Human oversight — HiTL, confidence gates, ESTOP' },
  { fria: 'hardware_observations',   article: 'Art. 17',     desc: 'Quality management — observed hardware behaviour' },
  { fria: 'Full document + sig',     article: 'Art. 27',     desc: 'FRIA obligation for public sector deployers' },
  { fria: 'spec_ref citation',       article: 'Annex IV',    desc: 'Technical documentation — citable specification reference' },
];

const safetyBenchmarksCode = `"safety_benchmarks": {
  "ref": "safety-benchmark-20260411.json",
  "generated_at": "2026-04-11T09:00:00.000Z",
  "mode": "synthetic",
  "overall_pass": true,
  "results": {
    "estop":           { "min_ms": 0.3, "mean_ms": 1.2, "p95_ms": 4.1,  "pass": true },
    "bounds_check":    { "min_ms": 0.1, "mean_ms": 0.4, "p95_ms": 0.9,  "pass": true },
    "confidence_gate": { "min_ms": 0.05,"mean_ms": 0.1, "p95_ms": 0.3,  "pass": true },
    "full_pipeline":   { "min_ms": 0.4, "mean_ms": 1.8, "p95_ms": 5.2,  "pass": true }
  }
}`;

const registryMetadataCode = `{
  "metadata": {
    "rrn": "rrn://org/robot/model/id",
    "robot_name": "my-robot",
    "compliance": {
      "annex_iii_basis": "safety_component",
      "fria_ref": "fria-20260411-signed.json"
    }
  }
}`;

const complianceDocs = [
  { doc: 'FRIA',                   schema: 'rcan-fria-v1',             article: 'Art. 43', generated: 'castor fria generate' },
  { doc: 'Safety Benchmark',       schema: 'rcan-safety-benchmark-v1', article: 'Art. 15', generated: 'castor safety benchmark' },
  { doc: 'Instructions for Use',   schema: 'rcan-ifu-v1',              article: 'Art. 13', generated: 'castor ifu generate' },
  { doc: 'Incident Log',           schema: 'rcan-incidents-v1',        article: 'Art. 72', generated: 'castor incidents' },
  { doc: 'EU Register Submission', schema: 'rcan-eu-register-v1',      article: 'Art. 49', generated: 'castor eu-register' },
];
---

<DocsLayout
  title="§22 FRIA Protocol — rcan.dev"
  description="RCAN §22 — Fundamental Rights Impact Assessment (FRIA) Protocol for EU AI Act compliance. Defines the signed FRIA document schema, conformance prerequisite, and CLI reference."
>
  <div class="max-w-3xl mx-auto">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-text-muted mb-6">
      <a href="/spec" class="hover:text-accent">Specification</a>
      <span>/</span>
      <span class="text-text">§22 FRIA Protocol</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-sm font-mono text-text-muted">§22</span>
        <span class="text-xs px-2 py-0.5 rounded-full border font-medium bg-amber-500/10 text-amber-400 border-amber-500/20">
          v1.0 Draft
        </span>
      </div>
      <h1 class="text-3xl font-bold text-text mb-3">FRIA Protocol</h1>
      <p class="text-text-muted text-lg leading-relaxed">
        Defines the Fundamental Rights Impact Assessment (FRIA) document format,
        conformance prerequisite, and ML-DSA-65 signing for EU AI Act notified body submission.
      </p>
    </div>

    <!-- Overview -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Overview</h2>
      <p class="text-text-muted leading-relaxed mb-4">
        EU AI Act Art. 27 requires deployers of high-risk AI systems to conduct a Fundamental Rights
        Impact Assessment before deployment. Annex IV specifies the technical file that must accompany
        a conformity assessment submission to a notified body. RCAN §22 defines a machine-readable FRIA
        document that can be generated automatically from live conformance data, signed with the robot's
        ML-DSA-65 identity key, and submitted as part of that technical file.
      </p>
      <p class="text-text-muted leading-relaxed mb-4">
        The FRIA document is generated by the <code class="text-accent">castor fria generate</code> CLI
        command, which sources data from <code class="text-accent">ConformanceChecker.run_all()</code>,
        the robot identity in the RCAN config, and <code class="text-accent">robot-memory.md</code>
        hardware observation entries. A print-ready HTML companion is generated alongside the canonical
        JSON artifact.
      </p>
      <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4 text-sm text-amber-400">
        <strong>Conformance:</strong> FRIA generation is required at L2+ (Secure tier and above).
        Deployments where <code>conformance.score &lt; 80</code> or any <code>safety.*</code> check
        fails are blocked unless <code>--force</code> is used (which sets <code>prerequisite_waived: true</code>).
      </div>
    </section>

    <!-- Document Schema -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Document Schema</h2>
      <CodeWindow code={friaSchema} language="json" title="FRIA Document — rcan-fria-v1" />

      <h3 class="text-base font-semibold text-text mt-6 mb-3">Field Reference</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left p-3 text-text font-semibold border-b border-border">Field</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Type</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Required</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Description</th>
            </tr>
          </thead>
          <tbody>
            {fields.map((f, i) => (
              <tr class={i % 2 === 0 ? 'bg-bg' : 'bg-bg-alt'}>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{f.field}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{f.type}</td>
                <td class="p-3 border-b border-border">
                  <span class={`text-xs font-medium ${f.req === 'MUST' ? 'text-green-400' : 'text-text-muted'}`}>
                    {f.req}
                  </span>
                </td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{f.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Annex III Bases -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Annex III Classification Bases</h2>
      <p class="text-text-muted text-sm mb-4">
        The <code class="text-accent">deployment.annex_iii_basis</code> field must be one of the following values,
        corresponding to the EU AI Act Annex III category under which the system is classified as high-risk.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left p-3 text-text font-semibold border-b border-border">Value</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Article</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Description</th>
            </tr>
          </thead>
          <tbody>
            {annexIiiBases.map((b, i) => (
              <tr class={i % 2 === 0 ? 'bg-bg' : 'bg-bg-alt'}>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{b.value}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{b.article}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{b.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Conformance Prerequisite -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Conformance Prerequisite</h2>
      <p class="text-text-muted text-sm leading-relaxed mb-4">
        Before generating a FRIA document, the runtime verifies two conditions:
      </p>
      <ul class="list-disc list-inside text-text-muted text-sm mb-4 space-y-1">
        <li>Conformance score &ge; 80/100 (100 &minus; (failures &times; 10) &minus; (warnings &times; 3))</li>
        <li>Zero <code class="text-accent">safety.*</code> check failures</li>
      </ul>
      <p class="text-text-muted text-sm leading-relaxed mb-4">
        If either condition fails, the command exits with a list of blocking checks and their
        recommended fixes. The <code class="text-accent">--force</code> flag bypasses the gate and
        sets <code class="text-accent">prerequisite_waived: true</code> in the document &mdash; this field
        is visible to the notified body and indicates the document is provisional.
      </p>
      <CodeWindow code={prerequisiteExample} language="bash" title="Conformance gate example" />
    </section>

    <!-- Signing -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Signing (ML-DSA-65)</h2>
      <p class="text-text-muted text-sm leading-relaxed mb-4">
        The FRIA document is signed with the robot's ML-DSA-65 identity key &mdash; the same key used
        for RCAN message signing (&sect;16.5). The signature covers the canonical JSON of the document
        with the <code class="text-accent">sig</code> field absent:
      </p>
      <ul class="list-disc list-inside text-text-muted text-sm mb-4 space-y-1">
        <li>Serialisation: <code class="text-accent">json.dumps(doc, sort_keys=True, separators=(',', ':'))</code></li>
        <li>Algorithm: ML-DSA-65 (NIST FIPS 204) &mdash; post-quantum secure</li>
        <li>Key binding: <code class="text-accent">signing_key.kid</code> identifies the key used</li>
        <li>Verification: use <code class="text-accent">signing_key.public_key</code> (base64url ML-DSA-65 public key)</li>
      </ul>
      <p class="text-text-muted text-sm leading-relaxed">
        Signing is required at L2+. Use <code class="text-accent">--skip-sign</code> only for
        development and testing &mdash; unsigned documents omit the <code class="text-accent">sig</code>
        and <code class="text-accent">signing_key</code> fields entirely.
      </p>
    </section>

    <!-- EU AI Act Mapping -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">EU AI Act Article Mapping</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left p-3 text-text font-semibold border-b border-border">FRIA Section</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">EU AI Act Provision</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Description</th>
            </tr>
          </thead>
          <tbody>
            {euMapping.map((m, i) => (
              <tr class={i % 2 === 0 ? 'bg-bg' : 'bg-bg-alt'}>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{m.fria}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border font-medium">{m.article}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{m.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Safety Benchmarks Integration -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Safety Benchmarks Integration</h2>
      <p class="text-text-muted text-sm leading-relaxed mb-4">
        The <code class="text-accent">safety_benchmarks</code> field is embedded in the FRIA document
        to provide quantitative evidence of runtime safety performance. Benchmark results are generated
        by <code class="text-accent">castor safety benchmark</code> and referenced inline. When
        <code class="text-accent">overall_pass: true</code>, the field satisfies the Art. 15 performance
        and accuracy evidence requirement for notified body review.
        See <a href="/spec/section-23" class="text-accent hover:underline">&sect;23 Safety Benchmark Protocol</a>
        for the full schema.
      </p>
      <CodeWindow code={safetyBenchmarksCode} language="json" title="FRIA safety_benchmarks block" />
    </section>

    <!-- Compliance Package -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Compliance Package</h2>
      <p class="text-text-muted text-sm leading-relaxed mb-4">
        A complete EU AI Act Art. 43 compliance submission for an Annex III system consists of the
        following companion artifacts, each with its own machine-readable schema and CLI generation command.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left p-3 text-text font-semibold border-b border-border">Document</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Schema</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Article</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Generated by</th>
            </tr>
          </thead>
          <tbody>
            {complianceDocs.map((d, i) => (
              <tr class={i % 2 === 0 ? 'bg-bg' : 'bg-bg-alt'}>
                <td class="p-3 text-text text-xs border-b border-border">{d.doc}</td>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{d.schema}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{d.article}</td>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{d.generated}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- v3.0 Breaking Change: Annex III fria_ref prerequisite -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">v3.0 Breaking Change: Annex III Registration Prerequisite</h2>
      <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4 text-sm text-amber-400 mb-4">
        <strong>v3.0 Breaking Change:</strong> <code>REGISTRY_REGISTER</code> for Annex III systems
        now requires <code>metadata.compliance.fria_ref</code>. Registration attempts without this
        field are rejected.
      </div>
      <p class="text-text-muted text-sm leading-relaxed mb-4">
        Prior to v3.0, <code class="text-accent">REGISTRY_REGISTER</code> accepted registrations for
        Annex III systems without a FRIA reference. From v3.0, the registry enforces that a signed
        FRIA document reference must be present in <code class="text-accent">metadata.compliance.fria_ref</code>
        before registration is accepted.
      </p>
      <CodeWindow code={registryMetadataCode} language="json" title="REGISTRY_REGISTER metadata (v3.0)" />
    </section>

    <!-- CLI Reference -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">CLI Reference</h2>
      <CodeWindow code={cliExample} language="bash" title="castor fria generate" />
      <div class="mt-4 bg-bg-alt border border-border rounded-lg p-4 text-sm text-text-muted">
        <p class="mb-2"><strong class="text-text">Outputs:</strong></p>
        <ul class="list-disc list-inside space-y-1">
          <li><code class="text-accent">fria-&#123;rrn&#125;-&#123;date&#125;.json</code> &mdash; Signed canonical JSON artifact (citable in Annex IV technical file)</li>
          <li><code class="text-accent">fria-&#123;rrn&#125;-&#123;date&#125;.html</code> &mdash; Print-ready HTML companion for notified body submission</li>
        </ul>
      </div>
    </section>

    <!-- Prev/Next -->
    <div class="flex justify-between items-center mt-12 pt-6 border-t border-border">
      <a href="/spec/section-21" class="flex items-center gap-2 text-text-muted hover:text-accent transition-colors">
        <span>&larr;</span>
        <span class="text-sm">&sect;21 Registry Integration</span>
      </a>
      <a href="/spec" class="flex items-center gap-2 text-text-muted hover:text-accent transition-colors">
        <span class="text-sm">Specification Index</span>
        <span>&rarr;</span>
      </a>
    </div>

  </div>
</DocsLayout>
