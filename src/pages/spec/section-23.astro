---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';

const benchmarkSchema = `{
  "schema": "rcan-safety-benchmark-v1",
  "generated_at": "2026-04-11T09:00:00.000Z",
  "mode": "synthetic",
  "iterations": 20,
  "thresholds": {
    "estop_p95_ms": 100.0,
    "bounds_check_p95_ms": 5.0,
    "confidence_gate_p95_ms": 2.0,
    "full_pipeline_p95_ms": 50.0
  },
  "results": {
    "estop":           { "min_ms": 0.3,  "mean_ms": 1.2, "p95_ms": 4.1,  "p99_ms": 7.2,  "max_ms": 9.8,  "pass": true },
    "bounds_check":    { "min_ms": 0.1,  "mean_ms": 0.4, "p95_ms": 0.9,  "p99_ms": 1.1,  "max_ms": 1.4,  "pass": true },
    "confidence_gate": { "min_ms": 0.05, "mean_ms": 0.1, "p95_ms": 0.3,  "p99_ms": 0.4,  "max_ms": 0.5,  "pass": true },
    "full_pipeline":   { "min_ms": 0.4,  "mean_ms": 1.8, "p95_ms": 5.2,  "p99_ms": 8.1,  "max_ms": 11.0, "pass": true }
  },
  "overall_pass": true
}`;

const cliExample = `# Run safety benchmark (synthetic — no hardware needed)
castor safety benchmark \\
  --config bob.rcan.yaml \\
  --iterations 20 \\
  --output safety-benchmark-20260411.json

# Include in FRIA:
castor fria generate \\
  --config bob.rcan.yaml \\
  --annex-iii-basis safety_component \\
  --intended-use "Indoor navigation" \\
  --benchmark safety-benchmark-20260411.json

# Fail CI when any path misses threshold:
castor safety benchmark --fail-fast`;

const paths = [
  { path: 'estop',           what: 'SafetyLayer.emergency_stop() call → halt state confirmed', threshold: '100 ms' },
  { path: 'bounds_check',    what: 'Motor command evaluated against all BoundsChecker limits',  threshold: '5 ms'   },
  { path: 'confidence_gate', what: 'Confidence value through ConfidenceGateEnforcer.evaluate()', threshold: '2 ms'  },
  { path: 'full_pipeline',   what: 'Command received → safety-cleared or blocked',              threshold: '50 ms'  },
];

const fields = [
  { field: 'schema',       type: 'string',  req: 'MUST',   desc: 'Always "rcan-safety-benchmark-v1".' },
  { field: 'generated_at', type: 'string',  req: 'MUST',   desc: 'ISO-8601 UTC timestamp.' },
  { field: 'mode',         type: 'string',  req: 'MUST',   desc: '"synthetic" or "live". Synthetic runs Python code paths directly; live connects to a running robot for the estop path only.' },
  { field: 'iterations',   type: 'integer', req: 'MUST',   desc: 'Number of timed iterations per path. Default: 20.' },
  { field: 'thresholds',   type: 'object',  req: 'MUST',   desc: 'P95 thresholds per path in milliseconds. Overridable via config safety.benchmark_thresholds.*.' },
  { field: 'results.*',    type: 'object',  req: 'MUST',   desc: 'Per-path stats: min_ms, mean_ms, p95_ms, p99_ms, max_ms, pass (true when p95 ≤ threshold).' },
  { field: 'overall_pass', type: 'boolean', req: 'MUST',   desc: 'True when every path passes its P95 threshold.' },
];
---

<DocsLayout
  title="§23 Safety Benchmark Protocol — rcan.dev"
  description="RCAN §23 — Safety Benchmark Protocol. Defines rcan-safety-benchmark-v1, quantified latency evidence for EU AI Act notified body review."
>
  <div class="max-w-3xl mx-auto">

    <nav class="flex items-center gap-2 text-sm text-text-muted mb-6">
      <a href="/spec" class="hover:text-accent">Specification</a>
      <span>/</span>
      <span class="text-text">§23 Safety Benchmark Protocol</span>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-sm font-mono text-text-muted">§23</span>
        <span class="text-xs px-2 py-0.5 rounded-full border font-medium bg-green-500/10 text-green-400 border-green-500/20">
          v3.0
        </span>
      </div>
      <h1 class="text-3xl font-bold text-text mb-3">Safety Benchmark Protocol</h1>
      <p class="text-text-muted text-lg leading-relaxed">
        Defines the <code class="text-accent">rcan-safety-benchmark-v1</code> schema — a machine-readable
        artifact that proves safety-critical software paths meet their latency thresholds.
        Required as quantified evidence for EU AI Act notified body review (Art. 15).
      </p>
    </div>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Overview</h2>
      <p class="text-text-muted leading-relaxed mb-4">
        EU AI Act Art. 15 requires high-risk AI systems to achieve appropriate levels of accuracy,
        robustness, and cybersecurity. For robot safety systems, this means quantified evidence that
        critical paths (ESTOP, bounds checking, confidence gating) perform within declared limits.
        RCAN §23 defines the benchmark schema and four canonical paths that together constitute
        the safety-path evidence package.
      </p>
      <p class="text-text-muted leading-relaxed mb-4">
        The benchmark runs in <strong class="text-text">synthetic mode</strong> by default — calling
        Python code paths directly with mock inputs, no hardware or running robot required.
        This makes it safe to run in CI. Live mode (<code class="text-accent">--live</code>) connects
        to a running robot for the ESTOP path only; the other three paths always run synthetic.
      </p>
      <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4 text-sm text-amber-400">
        <strong>FRIA integration:</strong> When <code>overall_pass: true</code>, reference the
        benchmark file in <code>castor fria generate --benchmark FILE</code>. The results are inlined
        under <code>safety_benchmarks</code> in the FRIA document. See §22.
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Benchmarked Paths</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left p-3 text-text font-semibold border-b border-border">Path</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">What is measured</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Default P95 threshold</th>
            </tr>
          </thead>
          <tbody>
            {paths.map((p, i) => (
              <tr class={i % 2 === 0 ? 'bg-bg' : 'bg-bg-alt'}>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{p.path}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{p.what}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border font-medium">{p.threshold}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-text-muted text-xs mt-3">
        The 100 ms ESTOP threshold matches the <code class="text-accent">MOTION_003</code> rule in SafetyLayer.
        All thresholds are overridable via <code class="text-accent">safety.benchmark_thresholds.*</code> in RCAN config.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Schema</h2>
      <CodeWindow code={benchmarkSchema} language="json" title="rcan-safety-benchmark-v1" />
      <h3 class="text-base font-semibold text-text mt-6 mb-3">Field Reference</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left p-3 text-text font-semibold border-b border-border">Field</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Type</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Required</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Description</th>
            </tr>
          </thead>
          <tbody>
            {fields.map((f, i) => (
              <tr class={i % 2 === 0 ? 'bg-bg' : 'bg-bg-alt'}>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{f.field}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{f.type}</td>
                <td class="p-3 border-b border-border">
                  <span class="text-xs font-medium text-green-400">{f.req}</span>
                </td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{f.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">CLI Reference</h2>
      <CodeWindow code={cliExample} language="bash" title="castor safety benchmark" />
    </section>

    <div class="flex justify-between items-center mt-12 pt-6 border-t border-border">
      <a href="/spec/section-22" class="flex items-center gap-2 text-text-muted hover:text-accent transition-colors">
        <span>&larr;</span>
        <span class="text-sm">&sect;22 FRIA Protocol</span>
      </a>
      <a href="/spec/section-24" class="flex items-center gap-2 text-text-muted hover:text-accent transition-colors">
        <span class="text-sm">&sect;24 Instructions for Use</span>
        <span>&rarr;</span>
      </a>
    </div>

  </div>
</DocsLayout>
