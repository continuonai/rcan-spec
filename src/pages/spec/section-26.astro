---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeWindow from '../../components/CodeWindow.astro';

const submissionSchema = `{
  "schema": "rcan-eu-register-v1",
  "generated_at": "2026-04-11T09:00:00.000Z",
  "fria_ref": "fria-RRN-000000000001-20260411-signed.json",
  "provider": {
    "name": "Example Corp",
    "contact": "safety@example.com"
  },
  "system": {
    "rrn": "RRN-000000000001",
    "rrn_uri": "rrn://org/robot/model/id",
    "robot_name": "my-robot",
    "rcan_version": "3.0",
    "opencastor_version": "2026.4.11.0"
  },
  "annex_iii_basis": "safety_component",
  "conformity_status": "declared",
  "submission_instructions": "Submit this package to the EU AI Act database at https://ec.europa.eu/digital-strategy/en/policies/european-ai-act. Include the referenced FRIA JSON as an attachment."
}`;

const cliExample = `# Generate EU register submission package
# Requires a valid signed FRIA document as input
castor eu-register \\
  --fria fria-bob-signed.json \\
  --config bob.rcan.yaml \\
  --output eu-register-bob-2026.json`;

const fields = [
  { field: 'schema',                 type: 'string', req: 'MUST',   desc: 'Always "rcan-eu-register-v1".' },
  { field: 'generated_at',           type: 'string', req: 'MUST',   desc: 'ISO-8601 UTC timestamp.' },
  { field: 'fria_ref',               type: 'string', req: 'MUST',   desc: 'Filename of the signed rcan-fria-v1 document included with this submission.' },
  { field: 'provider.name',          type: 'string', req: 'MUST',   desc: 'Provider organisation name.' },
  { field: 'provider.contact',       type: 'string', req: 'MUST',   desc: 'Provider contact email for notified body queries.' },
  { field: 'system.rrn',             type: 'string', req: 'MUST',   desc: 'Robot Registration Number.' },
  { field: 'system.rcan_version',    type: 'string', req: 'MUST',   desc: 'RCAN protocol version implemented.' },
  { field: 'annex_iii_basis',        type: 'string', req: 'MUST',   desc: 'Annex III classification basis (see §22 for valid values).' },
  { field: 'conformity_status',      type: 'string', req: 'MUST',   desc: '"declared" — self-declared conformity assessment per Art. 43.' },
  { field: 'submission_instructions',type: 'string', req: 'MUST',   desc: 'Human-readable instructions for completing the national database submission.' },
];
---

<DocsLayout
  title="§26 EU Register Submission — rcan.dev"
  description="RCAN §26 — EU Register Submission Protocol. Defines rcan-eu-register-v1, the Art. 49 submission package for the EU AI Act database."
>
  <div class="max-w-3xl mx-auto">

    <nav class="flex items-center gap-2 text-sm text-text-muted mb-6">
      <a href="/spec" class="hover:text-accent">Specification</a>
      <span>/</span>
      <span class="text-text">§26 EU Register Submission</span>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-sm font-mono text-text-muted">§26</span>
        <span class="text-xs px-2 py-0.5 rounded-full border font-medium bg-green-500/10 text-green-400 border-green-500/20">
          v3.0
        </span>
      </div>
      <h1 class="text-3xl font-bold text-text mb-3">EU Register Submission</h1>
      <p class="text-text-muted text-lg leading-relaxed">
        Defines the <code class="text-accent">rcan-eu-register-v1</code> schema — a submission package
        for the EU AI Act Art. 49 obligation to register high-risk AI systems in the EU AI database
        before placing them on the market.
      </p>
    </div>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Overview</h2>
      <p class="text-text-muted leading-relaxed mb-4">
        EU AI Act Art. 49 requires providers of high-risk AI systems to register their systems in
        the EU database administered by the European AI Office before placing the system on the market
        or putting it into service. RCAN §26 defines a submission package that wraps a signed FRIA
        document with the registration metadata required by the database.
      </p>
      <div class="bg-amber-500/10 border border-amber-500/20 rounded-lg p-4 text-sm text-amber-400">
        <strong>Prerequisite:</strong> A valid signed <code>rcan-fria-v1</code> document is required
        as input. The submission package references it by filename and the two files must be submitted
        together to the EU AI database.
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">Schema</h2>
      <CodeWindow code={submissionSchema} language="json" title="rcan-eu-register-v1" />

      <h3 class="text-base font-semibold text-text mt-6 mb-3">Field Reference</h3>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-border rounded-lg overflow-hidden">
          <thead>
            <tr class="bg-bg-alt">
              <th class="text-left p-3 text-text font-semibold border-b border-border">Field</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Type</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Required</th>
              <th class="text-left p-3 text-text font-semibold border-b border-border">Description</th>
            </tr>
          </thead>
          <tbody>
            {fields.map((f, i) => (
              <tr class={i % 2 === 0 ? 'bg-bg' : 'bg-bg-alt'}>
                <td class="p-3 font-mono text-accent text-xs border-b border-border">{f.field}</td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{f.type}</td>
                <td class="p-3 border-b border-border">
                  <span class="text-xs font-medium text-green-400">{f.req}</span>
                </td>
                <td class="p-3 text-text-muted text-xs border-b border-border">{f.desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-10">
      <h2 class="text-xl font-semibold text-text mb-3">CLI Reference</h2>
      <CodeWindow code={cliExample} language="bash" title="castor eu-register" />
    </section>

    <div class="flex justify-between items-center mt-12 pt-6 border-t border-border">
      <a href="/spec/section-25" class="flex items-center gap-2 text-text-muted hover:text-accent transition-colors">
        <span>&larr;</span>
        <span class="text-sm">&sect;25 Post-Market Monitoring</span>
      </a>
      <a href="/spec" class="flex items-center gap-2 text-text-muted hover:text-accent transition-colors">
        <span class="text-sm">Specification Index</span>
        <span>&rarr;</span>
      </a>
    </div>

  </div>
</DocsLayout>
