---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout title="§6 Safety Invariants" description="RCAN §6 — Safety Invariants. A set of non-negotiable safety rules that all RCAN implementations MUST enforce regardless of role or scope. This section covers emergency stop (ESTOP) propagation, SAFETY-priority message handling, rate-limit immunity for safety messages, and the physical safety boundary contract.">
  <div class="flex items-center gap-4 mb-4">
    <h1 class="mb-0">§6 Safety Invariants</h1>
  </div>
  <div class="flex gap-2 mb-8 flex-wrap">
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-500/10 text-green-400 border border-green-500/20">
      Status: Stable
    </span>
    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-accent/10 text-accent border border-accent/20">
      RCAN v1.3
    </span>
    <a href="/spec/" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white/5 text-text-muted border border-white/10 hover:border-white/20">
      ← Back to Specification
    </a>
  </div>

  <div class="not-prose bg-cyan-500/5 border border-cyan-500/20 rounded-xl p-6 mb-10">
    <p class="text-sm text-cyan-300/80">
      <strong class="text-cyan-400">Overview:</strong> A set of non-negotiable safety rules that all RCAN implementations MUST enforce regardless of role or scope. This section covers emergency stop (ESTOP) propagation, SAFETY-priority message handling, rate-limit immunity for safety messages, and the physical safety boundary contract.
    </p>
  </div>

  <div class="not-prose bg-bg-alt border border-white/5 rounded-xl p-8 mb-10 text-center">
    <p class="text-text-muted mb-6 text-sm">
      This section is part of the main RCAN Protocol Specification page. Individual section pages are planned for v1.4.
    </p>
    <a href="/spec/#safety" class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-bg font-bold rounded-lg hover:bg-accent-hover transition-colors">
      Read §6 in Full Specification →
    </a>
  </div>

  <div class="not-prose mt-12 flex flex-wrap gap-4">
    <a href="/spec/section-5/" class="inline-flex items-center gap-2 px-6 py-3 bg-bg-alt text-text border border-white/10 font-bold rounded-lg hover:border-white/20 transition-colors">← §5 Authentication</a>
    <a href="/spec/section-7/" class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-bg font-bold rounded-lg hover:bg-accent-hover transition-colors">§7 Federation →</a>
  </div>
</DocsLayout>
