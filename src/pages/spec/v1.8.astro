---
import DocsLayout from '../../layouts/DocsLayout.astro';

const changes = [
  { type: 'breaking', text: 'Canonical MessageType table — 36 types with fixed integer assignments. Both rcan-py and rcan-ts now use identical values. This is the SINGLE SOURCE OF TRUTH.' },
  { type: 'breaking', text: 'MessageType renumbering: TRANSPARENCY moved to 16, COMMAND_NACK to 18, KEY_ROTATION to 27, COMMAND_COMMIT to 28, SENSOR_DATA to 29. Old values are invalid.' },
  { type: 'feat', text: 'REGISTRY_REGISTER (14) and REGISTRY_RESOLVE (15) — dedicated message types for robot registry operations (§21).' },
  { type: 'feat', text: 'SENSOR_DATA (29) — raw sensor payload message type for telemetry and contribute data collection.' },
  { type: 'feat', text: 'TRAINING_DATA (36) — multi-modal training data payload, moved from 34 (collision with CONTRIBUTE_RESULT) and 10 (legacy rcan-ts).' },
  { type: 'feat', text: 'Deprecated aliases in rcan-ts: FEDERATION_SYNC → FLEET_COMMAND (23), ALERT → FAULT_REPORT (26), AUDIT → TRANSPARENCY (16). Will be removed in v2.1.' },
  { type: 'feat', text: '§3 Message Format rewritten with complete payload field reference for all 36 message types, scope requirements, and cross-references to relevant sections.' },
  { type: 'security', text: 'Cross-SDK compatibility tests verify all MessageType values match between rcan-py and rcan-ts at CI time.' },
  { type: 'chore', text: 'Compatibility: rcan-py ≥0.7.0, rcan-ts ≥0.7.0, OpenCastor ≥2026.3.20' },
];

const canonicalTable = [
  { value: 1, name: 'COMMAND', section: '§3', desc: 'Instruction to robot' },
  { value: 2, name: 'RESPONSE', section: '§3', desc: 'Response to command' },
  { value: 3, name: 'STATUS', section: '§3', desc: 'Robot state report' },
  { value: 4, name: 'HEARTBEAT', section: '§3', desc: 'Keepalive ping' },
  { value: 5, name: 'CONFIG', section: '§8', desc: 'Configuration update' },
  { value: 6, name: 'SAFETY', section: '§6', desc: 'Safety/ESTOP signal' },
  { value: 7, name: 'AUTH', section: '§5', desc: 'Authentication handshake' },
  { value: 8, name: 'ERROR', section: '§3', desc: 'Error response' },
  { value: 9, name: 'DISCOVER', section: '§4', desc: 'mDNS/network discovery' },
  { value: 10, name: 'PENDING_AUTH', section: '§5', desc: 'HiTL gate awaiting authorization' },
  { value: 11, name: 'INVOKE', section: '§19', desc: 'Skill/behavior invocation' },
  { value: 12, name: 'INVOKE_RESULT', section: '§19', desc: 'Result of INVOKE' },
  { value: 13, name: 'INVOKE_CANCEL', section: '§19', desc: 'Cancel in-progress invocation' },
  { value: 14, name: 'REGISTRY_REGISTER', section: '§21', desc: 'Register robot with RRF' },
  { value: 15, name: 'REGISTRY_RESOLVE', section: '§21', desc: 'Resolve RRN to RURI/metadata' },
  { value: 16, name: 'TRANSPARENCY', section: '§16', desc: 'EU AI Act Art. 13 audit record' },
  { value: 17, name: 'COMMAND_ACK', section: '§3', desc: 'QoS ≥ 1 acknowledgement' },
  { value: 18, name: 'COMMAND_NACK', section: '§3', desc: 'Negative acknowledgement' },
  { value: 19, name: 'ROBOT_REVOCATION', section: '§5', desc: 'Broadcast: revoke robot identity' },
  { value: 20, name: 'CONSENT_REQUEST', section: '§5', desc: 'Request cross-robot consent' },
  { value: 21, name: 'CONSENT_GRANT', section: '§5', desc: 'Owner grants consent' },
  { value: 22, name: 'CONSENT_DENY', section: '§5', desc: 'Owner denies consent' },
  { value: 23, name: 'FLEET_COMMAND', section: '§15', desc: 'Broadcast to robot group' },
  { value: 24, name: 'SUBSCRIBE', section: '§13', desc: 'Subscribe to telemetry stream' },
  { value: 25, name: 'UNSUBSCRIBE', section: '§13', desc: 'Cancel telemetry subscription' },
  { value: 26, name: 'FAULT_REPORT', section: '§6', desc: 'Structured fault report' },
  { value: 27, name: 'KEY_ROTATION', section: '§5', desc: 'Key rotation broadcast' },
  { value: 28, name: 'COMMAND_COMMIT', section: '§3', desc: 'Exactly-once commit phase' },
  { value: 29, name: 'SENSOR_DATA', section: '§12', desc: 'Raw sensor payload' },
  { value: 30, name: 'TRAINING_CONSENT_REQUEST', section: '§5', desc: 'Training data consent request' },
  { value: 31, name: 'TRAINING_CONSENT_GRANT', section: '§5', desc: 'Training data consent grant' },
  { value: 32, name: 'TRAINING_CONSENT_DENY', section: '§5', desc: 'Training data consent deny' },
  { value: 33, name: 'CONTRIBUTE_REQUEST', section: 'v1.7', desc: 'Coordinator → robot: deliver work unit' },
  { value: 34, name: 'CONTRIBUTE_RESULT', section: 'v1.7', desc: 'Robot → coordinator: return results' },
  { value: 35, name: 'CONTRIBUTE_CANCEL', section: 'v1.7', desc: 'Robot → coordinator: cancellation' },
  { value: 36, name: 'TRAINING_DATA', section: 'v1.8', desc: 'Multi-modal training data payload' },
];

const typeStyle: Record<string, string> = {
  breaking: 'bg-red-500/10 text-red-400 border-red-500/20',
  feat:     'bg-accent/10 text-accent border-accent/20',
  fix:      'bg-green-500/10 text-green-400 border-green-500/20',
  security: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
  chore:    'bg-gray-500/10 text-gray-400 border-gray-500/20',
};
---

<DocsLayout title="RCAN v1.8 — MessageType Canonicalization" description="RCAN v1.8 changelog: canonical MessageType table, cross-SDK alignment, 36 message types with fixed integer assignments.">
  <div class="flex items-center gap-4 mb-4">
    <a href="/spec/" class="text-sm text-muted hover:text-accent">&larr; Spec</a>
    <span class="text-muted">/</span>
    <span class="text-sm font-medium">v1.8</span>
  </div>

  <h1 class="mb-0">RCAN v1.8 — MessageType Canonicalization</h1>
  <p class="text-muted mt-1 mb-8">March 2026</p>

  <section class="mb-12">
    <h2>Overview</h2>
    <p>
      v1.8 establishes the <strong>canonical MessageType table</strong> &mdash; a single source of truth for all
      36 RCAN message type integer assignments. Prior to v1.8, the spec, rcan-py, and rcan-ts had diverged on
      values 7&ndash;29, causing interoperability issues. This release eliminates all drift.
    </p>
    <p>
      Both SDK implementations (rcan-py and rcan-ts) now use identical integer assignments verified by
      cross-SDK compatibility tests in CI.
    </p>
  </section>

  <section class="mb-12">
    <h2>Breaking Changes</h2>
    <div class="not-prose bg-red-500/5 border border-red-500/20 rounded-xl p-6 mb-6">
      <p class="text-sm text-red-300/80">
        <strong class="text-red-400">Migration required:</strong> If your code depends on specific MessageType
        integer values (e.g., for binary protocols, database storage, or wire format parsing), you must update
        to the v1.8 canonical values. The affected ranges are values 7&ndash;18 and 27&ndash;29.
      </p>
    </div>

    <h3>Renamed/Renumbered Types</h3>
    <table class="w-full text-sm border-collapse mt-4">
      <thead>
        <tr class="border-b border-white/10">
          <th class="text-left py-2">Type</th>
          <th class="text-left py-2">Old (rcan-py)</th>
          <th class="text-left py-2">Old (rcan-ts)</th>
          <th class="text-left py-2">v1.8 Canonical</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">AUTH</td><td>7</td><td>—</td><td class="text-accent font-bold">7</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">ERROR</td><td>—</td><td>16</td><td class="text-accent font-bold">8</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">DISCOVER</td><td>—</td><td>9</td><td class="text-accent font-bold">9</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">INVOKE_CANCEL</td><td>12</td><td>—</td><td class="text-accent font-bold">13</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">TRANSPARENCY</td><td>18</td><td>11</td><td class="text-accent font-bold">16</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">COMMAND_NACK</td><td>28</td><td>27</td><td class="text-accent font-bold">18</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">KEY_ROTATION</td><td>27</td><td>—</td><td class="text-accent font-bold">27</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">COMMAND_COMMIT</td><td>29</td><td>18</td><td class="text-accent font-bold">28</td></tr>
        <tr class="border-b border-white/5"><td class="py-2 font-mono text-xs">SENSOR_DATA</td><td>—</td><td>7</td><td class="text-accent font-bold">29</td></tr>
        <tr><td class="py-2 font-mono text-xs">TRAINING_DATA</td><td>34</td><td>10</td><td class="text-accent font-bold">36</td></tr>
      </tbody>
    </table>

    <h3 class="mt-8">Deprecated Aliases (rcan-ts only)</h3>
    <p class="text-sm text-muted">These aliases exist for backward compatibility and will be removed in v2.1:</p>
    <ul class="text-sm mt-2 space-y-1">
      <li><code>FEDERATION_SYNC</code> &rarr; use <code>FLEET_COMMAND</code> (23)</li>
      <li><code>ALERT</code> &rarr; use <code>FAULT_REPORT</code> (26)</li>
      <li><code>AUDIT</code> &rarr; use <code>TRANSPARENCY</code> (16)</li>
    </ul>
  </section>

  <section class="mb-12">
    <h2>Canonical MessageType Table</h2>
    <p class="text-sm text-muted mb-4">
      This is the single source of truth. Both rcan-py and rcan-ts MUST use these exact integer assignments.
    </p>
    <div class="not-prose overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-white/10">
            <th class="text-left py-2 w-12">Value</th>
            <th class="text-left py-2">Name</th>
            <th class="text-left py-2 w-16">Section</th>
            <th class="text-left py-2">Description</th>
          </tr>
        </thead>
        <tbody>
          {canonicalTable.map(row => (
            <tr class="border-b border-white/5">
              <td class="py-1.5 font-mono text-accent text-xs">{row.value}</td>
              <td class="py-1.5 font-mono text-xs">{row.name}</td>
              <td class="py-1.5 text-xs text-muted">{row.section}</td>
              <td class="py-1.5 text-xs text-muted">{row.desc}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="mb-12">
    <h2>Changelog</h2>
    <div class="space-y-3">
      {changes.map(c => (
        <div class={`flex gap-3 items-start p-3 rounded-lg border ${typeStyle[c.type]}`}>
          <span class="text-xs font-mono uppercase tracking-wider mt-0.5 shrink-0">{c.type}</span>
          <span class="text-sm">{c.text}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="mb-12">
    <h2>Cross-SDK Compatibility</h2>
    <p>
      Starting with v1.8, both SDK CI pipelines include a compatibility test that verifies all MessageType
      integer values match the canonical table. Any drift will fail CI immediately.
    </p>
    <div class="not-prose bg-green-500/5 border border-green-500/20 rounded-xl p-6 mt-4">
      <p class="text-sm text-green-300/80">
        <strong class="text-green-400">Verified:</strong> As of v1.8 release, all 36 message types are
        identical between rcan-py and rcan-ts. Zero mismatches.
      </p>
    </div>
  </section>

  <section>
    <h2>Migration Guide</h2>
    <h3>rcan-py users</h3>
    <ul class="text-sm space-y-1">
      <li>Update to rcan-py ≥0.7.0</li>
      <li>If you used <code>MessageType.AUTHORIZE</code> (was 8), it is removed &mdash; use <code>AUTH</code> (7)</li>
      <li>If you stored integer values in databases, update: TRANSPARENCY 18&rarr;16, COMMAND_NACK 28&rarr;18, COMMAND_COMMIT 29&rarr;28</li>
    </ul>
    <h3 class="mt-4">rcan-ts users</h3>
    <ul class="text-sm space-y-1">
      <li>Update to rcan-ts ≥0.7.0</li>
      <li><code>SENSOR_DATA</code> moved from 7 to 29, <code>TRAINING_DATA</code> from 10 to 36</li>
      <li><code>FEDERATION_SYNC</code>, <code>ALERT</code>, <code>AUDIT</code> are deprecated aliases &mdash; migrate to canonical names</li>
      <li>Types <code>TELEOP</code> (14), <code>CHAT</code> (15) are removed &mdash; use <code>COMMAND</code> with appropriate scope</li>
    </ul>
  </section>
</DocsLayout>
