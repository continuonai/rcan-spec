---
import DocsLayout from '../../layouts/DocsLayout.astro';

const features = [
  { text: 'M2M_TRUSTED (level 6): RRF-issued fleet orchestration tokens. Enables cross-fleet COMMAND/INVOKE/CONFIG without per-robot CREATOR approval. Multi-owner consent required.' },
  { text: 'fleet.trusted scope: new scope gated to M2M_TRUSTED only. Required for any message issued by an orchestration system.' },
  { text: 'RRF orchestrator registry: new RRF API endpoint for registering orchestration systems, managing consent, and issuing/revoking M2M_TRUSTED tokens.' },
  { text: 'Revocation polling protocol: receivers with active M2M_TRUSTED sessions MUST poll the RRF revocation list at ≤ 60 s intervals.' },
  { text: 'Multi-owner consent: CONSENT_GRANT (21) / CONSENT_DENY (22) messages to RRF for fleet enrollment.' },
];

const constraints = [
  { text: 'M2M_TRUSTED tokens are issued by RRF only — no self-issuance, no CREATOR-issuance.' },
  { text: 'M2M_TRUSTED tokens expire in ≤ 24 h and MUST be re-issued with RRF re-validation.' },
  { text: 'fleet_rrns MUST be an explicit list — no wildcard fleet access.' },
  { text: 'M2M_TRUSTED MUST NOT issue further tokens to other principals.' },
  { text: 'ESTOP (Priority.SAFETY) is ALWAYS honored regardless of role level — level 6 does not bypass safety.' },
  { text: 'Any CREATOR can revoke consent at any time; revocation takes effect within one poll interval (≤ 60 s).' },
  { text: 'v1.x receivers MUST reject rcan_role: "m2m_trusted" tokens. v2.1 is a clean break — no v1.x/v2.1 mixed fleets.' },
];
---

