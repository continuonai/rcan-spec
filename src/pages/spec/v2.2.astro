---
import DocsLayout from '../../layouts/DocsLayout.astro';

const notices = [
  { text: 'RCAN v2.2 introduces hybrid PQ signing: ML-DSA-65 (NIST FIPS 204) alongside Ed25519. Old robots verify Ed25519 only; new robots verify both.' },
  { text: 'Q-Day revised to 2029 (Google, March 2026). All signature stacks SHOULD migrate to hybrid mode before 2027.' },
  { text: 'dilithium-py (Python) and @noble/post-quantum (TypeScript) are the reference implementations. Both are pure-software, no native deps.' },
  { text: 'v2.2 is backward-compatible with v2.1: pq_sig field is additive. v2.1 receivers ignore pq_sig; v2.2 receivers check both.' },
];

const conformanceLevels = [
  { level: 'L0', label: 'Unsafe',      req: 'No authentication, no signing.' },
  { level: 'L1', label: 'Baseline',    req: 'Ed25519 message signing (§9). HiTL gates.' },
  { level: 'L2', label: 'Secure',      req: 'L1 + Ed25519 hybrid with ML-DSA-65 pq_sig (§7.2). Firmware hash.' },
  { level: 'L3', label: 'Auditable',   req: 'L2 + AuditChain + signed RURI.' },
  { level: 'L4', label: 'Federated',   req: 'L3 + M2M_PEER, RBAC, delegation chain.' },
  { level: 'L5', label: 'Compliant',   req: 'L4 + M2M_TRUSTED, RRF registration, SBOM (RRF-countersigned), firmware manifest, authority handler, audit retention ≥10yr, EU AI Act §12/§16.' },
];

const pqTimeline = [
  { period: '2026–2028', phase: 'Hybrid',           desc: 'Messages carry both Ed25519 (sig) and ML-DSA-65 (pq_sig). New robots generate ML-DSA-65 key at boot. Verifiers check both when available.' },
  { period: '2028',      phase: 'ML-DSA Primary',   desc: 'ML-DSA-65 is the default signing algorithm. Ed25519 accepted for verification only (no new keys generated). RCAN v3.0 alpha.' },
  { period: '2029',      phase: 'Ed25519 Sunset',   desc: 'Ed25519 signing removed. All robots MUST use ML-DSA-65. castor migrate --crypto rotates keys. NIST IR 8547 compliance deadline.' },
];

const newFields = [
  { field: 'pq_sig',   type: 'object | null',  desc: 'ML-DSA-65 signature block (FIPS 204). Keys: alg ("ml-dsa-65"), kid (8-char hex), sig (base64url). Absent on pre-v2.2 messages.' },
  { field: 'pq_alg',   type: 'string',         desc: 'Deprecated synonym for pq_sig.alg — use pq_sig.alg directly.' },
];
---

<DocsLayout title="RCAN v2.2 Snapshot" description="RCAN v2.2 specification snapshot. PQ hybrid signing: ML-DSA-65 (FIPS 204) + Ed25519. Q-Day protection for robot boot sequences and firmware attestation.">

  <h1 class="mb-0">RCAN v2.2 Specification Snapshot</h1>
  <p class="text-muted mt-1 mb-6">Post-Quantum Hybrid Signing — ML-DSA-65 (NIST FIPS 204) + Ed25519</p>

  <!-- Notices -->
  <div class="space-y-2 mb-8">
    {notices.map(n => (
      <div class="bg-yellow-500/10 border border-yellow-500/30 rounded px-4 py-2 text-sm">
        ⚠️ {n.text}
